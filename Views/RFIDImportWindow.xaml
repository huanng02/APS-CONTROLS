<Window x:Class="QuanLyGiuXe.Views.RFIDImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import RFIDCards" Height="600" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Button x:Name="BtnChoose" Content="Chọn file" Width="120" Margin="0,0,8,0" Click="BtnChoose_Click"/>
            <TextBlock x:Name="TxtPath" VerticalAlignment="Center" />
            <Button x:Name="BtnPreview" Content="Preview" Width="100" Margin="12,0,0,0" Click="BtnPreview_Click"/>
            <Button x:Name="BtnImport" Content="Import" Width="120" Margin="12,0,0,0" Click="BtnImport_Click"/>
        </StackPanel>

        <DataGrid x:Name="PreviewGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="48"/>
                <DataGridTextColumn Header="CardUID" Binding="{Binding CardUID}" Width="150"/>
                <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120"/>
                <DataGridTextColumn Header="Loại xe" Binding="{Binding LoaiXe}" Width="120"/>
                <DataGridTextColumn Header="Loại vé" Binding="{Binding LoaiVe}" Width="120"/>
                <DataGridTextColumn Header="Ngày đăng ký" Binding="{Binding NgayDangKy, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Ngày hết hạn" Binding="{Binding NgayHetHan, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
            <ProgressBar x:Name="ProgressBar" Width="300" Height="18" Minimum="0" Maximum="100" Margin="0,0,12,0"/>
            <TextBlock x:Name="TxtStats" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
