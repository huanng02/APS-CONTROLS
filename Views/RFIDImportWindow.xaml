<Window x:Class="QuanLyGiuXe.Views.RFIDImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BULK RFID IMPORT" Height="700" Width="1000" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgLightBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource EnterpriseCardBorder}" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnChoose" Content="📁 SELECT FILE" Style="{StaticResource ModernOutlineButton}" Width="150" Margin="0,0,12,0" Click="BtnChoose_Click"/>
                <TextBox x:Name="TxtPath" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Width="350" VerticalAlignment="Center" Padding="10,8"/>
                
                <Border Width="1" Background="{StaticResource BorderLightBrush}" Margin="20,5"/>
                
                <Button x:Name="BtnPreview" Content="👁️ PREVIEW" Style="{StaticResource ModernButton}" Background="{StaticResource APSBlueBrush}" Width="130" Margin="0,0,10,0" Click="BtnPreview_Click"/>
                <Button x:Name="BtnImport" Content="🚀 IMPORT DATA" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="150" Click="BtnImport_Click"/>
            </StackPanel>
        </Border>

        <!-- Preview Grid -->
        <Border Grid.Row="1" Style="{StaticResource EnterpriseCardBorder}" Padding="0">
            <DataGrid x:Name="PreviewGrid" Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="INDEX" Binding="{Binding RowNumber}" Width="70"/>
                    <DataGridTextColumn Header="CARD UID" Binding="{Binding CardUID}" Width="150"/>
                    <DataGridTextColumn Header="LICENSE PLATE" Binding="{Binding BienSo}" Width="130"/>
                    <DataGridTextColumn Header="HOLDER NAME" Binding="{Binding CardName}" Width="*"/>
                    <DataGridTextColumn Header="VEHICLE" Binding="{Binding LoaiXe}" Width="120"/>
                    <DataGridTextColumn Header="TICKET" Binding="{Binding LoaiVe}" Width="120"/>
                    <DataGridTextColumn Header="ISSUE DATE" Binding="{Binding NgayDangKy, StringFormat=dd/MM/yyyy}" Width="130"/>
                    <DataGridTextColumn Header="EXPIRY DATE" Binding="{Binding NgayHetHan, StringFormat=dd/MM/yyyy}" Width="130"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding TrangThai}" Width="120"/>
                    <DataGridTextColumn Header="RESULT" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="LOG MESSAGE" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status & Progress -->
        <Border Grid.Row="2" Style="{StaticResource EnterpriseCardBorder}" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStats" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource APSBlueBrush}"/>
                <ProgressBar x:Name="ProgressBar" Grid.Column="1" Height="6" Minimum="0" Maximum="100" Margin="30,0" Background="{StaticResource BgLightBrush}" Foreground="{StaticResource SuccessBrush}" BorderThickness="0"/>
                <TextBlock Grid.Column="2" Text="READY" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Opacity="0.6"/>
            </Grid>
        </Border>
    </Grid>
</Window>

