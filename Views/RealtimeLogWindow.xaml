<Window x:Class="QuanLyGiuXe.Views.RealtimeLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuanLyGiuXe.Converters"
        Title="Enterprise Real-time Log Dashboard" 
        Height="768" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}">

    <Window.Resources>
        <local:EventToBrushConverter x:Key="EventToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:BoolToTextConverter x:Key="BoolToTextConverter" />
        <local:BoolToTextConverter x:Key="AutoScrollConverter" TrueText="📜 Auto Scroll: ON" FalseText="📜 Auto Scroll: OFF" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Style="{StaticResource ModernCardBorder}" Margin="0,0,0,15" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon -->
                    <Border Background="#1AFFFFFF" CornerRadius="8" Padding="10" Margin="0,0,15,0">
                        <TextBlock Text="⚡" FontSize="24" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="REAL-TIME SYSTEM LOGS" Style="{StaticResource ModernTitleTextBlock}" Foreground="{StaticResource AccentCyanBrush}"/>
                        <TextBlock Text="Giám sát mọi hoạt động của hệ thống theo thời gian thực" Style="{StaticResource ModernTextBlock}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="TogglePause" Margin="0,0,10,0"
                                  Command="{Binding PauseLogCommand}"
                                  Content="{Binding IsPaused, Converter={StaticResource BoolToTextConverter}, FallbackValue='⏸ Pause Log'}"
                                  Style="{StaticResource ModernOutlineButton}"/>
                    
                    <Button Margin="0,0,10,0"
                                  Command="{Binding ToggleAutoScrollCommand}"
                                  Content="{Binding AutoScroll, Converter={StaticResource AutoScrollConverter}, FallbackValue='📜 Auto Scroll'}"
                                  Style="{StaticResource ModernOutlineButton}"/>

                    <Button Content="🗑 Clear" Command="{Binding ClearLogCommand}" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                    <Button Content="📥 Export" Command="{Binding ExportLogCommand}" Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTERS -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardBorder}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Level:" Style="{StaticResource ModernTextBlock}" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding Levels}" 
                              SelectedItem="{Binding SelectedLevel}" 
                              Style="{StaticResource ModernComboBox}" 
                              Width="150" Margin="0,0,20,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tìm kiếm:" Style="{StaticResource ModernTextBlock}" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernSearchBox}" 
                             Width="300" 
                             ToolTip="Nhập nội dung, biển số, sự kiện..."/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LogEntries.Count, StringFormat='{}Total: {0} logs in buffer'}" Style="{StaticResource ModernTextBlock}" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN DATA GRID -->
        <Border Grid.Row="2" Style="{StaticResource ModernCardBorder}" Padding="1">
            <DataGrid x:Name="LogGrid" ItemsSource="{Binding LogView}" 
                      Style="{StaticResource ModernDataGrid}"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                
                <!-- ROW DETAILS (Expandable) -->
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Background="#1A000000" Padding="15" Margin="5" CornerRadius="6" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="System Info" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding MachineName, StringFormat='{}Machine: {0}'}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding IpAddress, StringFormat='{}IP: {0}'}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding CorrelationId, StringFormat='{}Trace ID: {0}'}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Audit Detail" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding OldValues, StringFormat='{}Old: {0}'}" Foreground="#FFC0C0" Margin="0,0,0,2" Visibility="{Binding OldValues, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding NewValues, StringFormat='{}New: {0}'}" Foreground="#C0FFC0" Visibility="{Binding NewValues, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    
                                    <!-- Exception StackTrace -->
                                    <TextBlock Text="{Binding Exception}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="TIME" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="110" />
                    
                    <DataGridTemplateColumn Header="LEVEL" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Info">
                                                    <Setter Property="Background" Value="#3300D2FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Background" Value="#33FFD700"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Background" Value="#33FF5252"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Security">
                                                    <Setter Property="Background" Value="#339C27B0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <TextBlock Text="{Binding Level}" FontWeight="Bold" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Info">
                                                        <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Security">
                                                        <Setter Property="Foreground" Value="#E040FB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="120" />
                    <DataGridTextColumn Header="EVENT" Binding="{Binding EventType}" Width="150" />
                    <DataGridTextColumn Header="USER" Binding="{Binding Username}" Width="100" />
                    <DataGridTextColumn Header="PLATE" Binding="{Binding Plate}" Width="100" />
                    
                    <DataGridTemplateColumn Header="DETAILS" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Details}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Details}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
