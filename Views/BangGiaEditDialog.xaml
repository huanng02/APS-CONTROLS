<Window x:Class="QuanLyGiuXe.Views.BangGiaEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PRICE CONFIGURATION" Height="300" Width="480" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgLightBrush}">
    <Grid Margin="20">
        <Border Style="{StaticResource EnterpriseCardBorder}" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="PRICING ADJUSTMENT" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1">
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="VEHICLE TYPE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="tbLoaiXe" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Opacity="0.7"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MONTHLY RATE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="tbGiaThang" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <TextBlock Text="* Time-based slot prices are managed in advanced settings." 
                               Style="{StaticResource SubTitleStyle}" FontStyle="Italic" Margin="120,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="CANCEL" Style="{StaticResource ModernOutlineButton}" Width="110" Margin="0,0,10,0" Click="Cancel_Click" />
                    <Button Content="SAVE RATE" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="140" Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

