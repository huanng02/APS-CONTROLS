<Window x:Class="QuanLyGiuXe.Views.KhungGioAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm khung giờ mới" Height="320" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="THÊM MỚI KHUNG GIỜ" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>

        <!-- Tên khung -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Tên khung giờ:" VerticalAlignment="Center" FontWeight="Medium"/>
            <TextBox x:Name="txtTenKhung" Grid.Column="1" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#CCCCCC" BorderThickness="1"/>
        </Grid>

        <!-- Start time -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Thời gian bắt đầu:" VerticalAlignment="Center" FontWeight="Medium"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ComboBox x:Name="cbStartHour" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
                <TextBlock Text=":" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                <ComboBox x:Name="cbStartMin" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
                <TextBlock Text=":" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                <ComboBox x:Name="cbStartSec" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- End time -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Thời gian kết thúc:" VerticalAlignment="Center" FontWeight="Medium"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ComboBox x:Name="cbEndHour" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
                <TextBlock Text=":" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                <ComboBox x:Name="cbEndMin" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
                <TextBlock Text=":" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                <ComboBox x:Name="cbEndSec" Width="55" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="TimeSelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Error Text & Existing Slots Info -->
        <StackPanel Grid.Row="4" Margin="0,5,0,0">
            <TextBlock x:Name="txtExisting" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,5" FontStyle="Italic"/>
            <TextBlock x:Name="txtError" Foreground="#F44336" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="💾 Lưu" Width="90" Height="35" Margin="0,0,10,0" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
            <Button Content="✖ Huỷ" Width="90" Height="35" Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
