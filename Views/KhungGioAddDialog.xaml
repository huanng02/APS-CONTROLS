<Window x:Class="QuanLyGiuXe.Views.KhungGioAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm khung giờ mới"
        Width="500"
        SizeToContent="Height"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Background="#2196F3"
                        Width="42"
                        Height="42"
                        CornerRadius="8"
                        Margin="0,0,12,0">
                    <TextBlock Text="⏰"
                               FontSize="18"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>

                <StackPanel>
                    <TextBlock Text="THÊM KHUNG GIỜ"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>

                    <TextBlock Text="Cấu hình thời gian hoạt động"
                               FontSize="13"
                               Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>

            <!-- Tên -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tên khung giờ"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#334155"/>

                <TextBox x:Name="txtTenKhung"
                         Grid.Column="1"
                         Height="36"
                         Padding="10,0"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         Background="White"/>
            </Grid>

            <!-- Start -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Giờ bắt đầu"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#334155"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <ComboBox x:Name="cbStartHour"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>

                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbStartMin"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>

                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbStartSec"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- End -->
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Giờ kết thúc"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#334155"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <ComboBox x:Name="cbEndHour"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>

                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbEndMin"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>

                    <TextBlock Text=":"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbEndSec"
                              Width="70"
                              Height="36"
                              SelectionChanged="TimeSelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="4">

                <!-- Existing -->
                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,10">

                    <ScrollViewer MaxHeight="120"
                                  VerticalScrollBarVisibility="Auto">

                        <TextBlock x:Name="txtExisting"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <!-- Error -->
                <Border x:Name="errorBorder"
                        Background="#FEF2F2"
                        BorderBrush="#EF4444"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Visibility="Collapsed">

                    <TextBlock x:Name="txtError"
                               Foreground="#DC2626"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnSave"
                        Grid.Column="1"
                        Content="💾 Lưu"
                        Width="110"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="BtnSave_Click"
                        Background="#2196F3"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="✖ Huỷ"
                        Width="110"
                        Height="40"
                        Click="BtnCancel_Click"
                        Background="#94A3B8"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>