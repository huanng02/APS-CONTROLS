<Window x:Class="QuanLyGiuXe.Views.QuanLyTheWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RFID Management System"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

	<Grid Margin="15">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ================= TITLE BAR ================= -->
		<Border Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,10">

			<DockPanel>

				<StackPanel>
					<TextBlock Text="📡 QUẢN LÝ THẺ RFID"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#2F3542"/>

					<TextBlock Text="Quản lý thẻ xe, phân quyền, trạng thái và biển số"
                               Foreground="Gray"
                               FontSize="12"/>
				</StackPanel>

			</DockPanel>
		</Border>

		<!-- ================= TOOLBAR ================= -->
		<Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,10">

			<Grid>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- FILTER AREA -->
				<StackPanel Orientation="Horizontal">

					<!-- SEARCH -->
					<TextBox Width="220"
                             Height="32"
                             Margin="0,0,10,0"
                             Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Tìm UID / Biển số / Loại thẻ"/>

					<!-- UID -->
					<TextBox Width="140"
                             Margin="0,0,10,0"
                             Text="{Binding FilterUID, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Lọc theo UID RFID"/>

					<!-- BIỂN SỐ -->
					<TextBox Width="140"
                             Margin="0,0,10,0"
                             Text="{Binding FilterBienSo, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Lọc theo biển số"/>

					<!-- TYPE -->
					<ComboBox Width="120"
                              Margin="0,0,10,0"
                              SelectedItem="{Binding FilterLoaiThe}">
						<ComboBoxItem Content="All"/>
						<ComboBoxItem Content="Xe máy"/>
						<ComboBoxItem Content="Ô tô"/>
						<ComboBoxItem Content="VIP"/>
					</ComboBox>

					<!-- STATUS -->
					<ComboBox Width="120"
                              Margin="0,0,10,0"
                              SelectedItem="{Binding FilterTrangThai}">
						<ComboBoxItem Content="All"/>
						<ComboBoxItem Content="Active"/>
						<ComboBoxItem Content="Blocked"/>
					</ComboBox>

				</StackPanel>

				<!-- ACTION BUTTONS -->
				<StackPanel Grid.Column="1" Orientation="Horizontal">

					<Button Content="➕ Thêm thẻ"
                            Width="120"
                            Margin="5,0"
                            Background="#2ED573"
                            Foreground="White"
                            ToolTip="Thêm thẻ RFID mới"
                            Click="ThemThe_Click"/>

					<Button Content="🔄 Làm mới"
                            Width="100"
                            Margin="5,0"
                            Background="#3742FA"
                            Foreground="White"
                            ToolTip="Tải lại danh sách"
                            Click="Refresh_Click"/>

					<Button Content="🧹 Reset"
                            Width="90"
                            Margin="5,0"
                            Background="#FF4757"
                            Foreground="White"
                            ToolTip="Xóa bộ lọc"
                            Click="ResetFilter_Click"/>

				</StackPanel>

			</Grid>
		</Border>

		<!-- ================= TABLE ================= -->
		<Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="10">

			<DataGrid ItemsSource="{Binding DanhSachRFID}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      HeadersVisibility="Column">

				<DataGrid.Columns>

					<DataGridTextColumn Header="🔑 UID RFID"
                                        Binding="{Binding CardUID}"
                                        Width="2*"/>

					<DataGridTextColumn Header="🚗 Biển số"
                                        Binding="{Binding BienSo}"
                                        Width="2*"/>

					<DataGridTextColumn Header="🏷 Loại thẻ"
                                        Binding="{Binding LoaiThe}"
                                        Width="*"/>

					<DataGridTextColumn Header="📌 Trạng thái"
                                        Binding="{Binding TrangThai}"
                                        Width="*"/>

					<DataGridTemplateColumn Header="⚙ Chức năng" Width="*">

						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>

								<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

									<Button Content="Sửa"
                                            Width="60"
                                            Margin="3"
                                            Background="#FFA502"
                                            Foreground="White"
                                            ToolTip="Chỉnh sửa thẻ"
                                            Click="SuaThe_Click"/>

									<Button Content="Xóa"
                                            Width="60"
                                            Margin="3"
                                            Background="#FF4757"
                                            Foreground="White"
                                            ToolTip="Xóa thẻ"
                                            Click="XoaThe_Click"/>

								</StackPanel>

							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>

					</DataGridTemplateColumn>

				</DataGrid.Columns>

			</DataGrid>

		</Border>

		<!-- ================= FOOTER ================= -->
		<Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="10"
                Margin="0,10,0,0">

			<DockPanel>

				<TextBlock Text="{Binding DanhSachRFID.Count, StringFormat=Tổng số thẻ: {0}}"
                           FontWeight="Bold"
                           Foreground="#333"
                           DockPanel.Dock="Left"/>

				<TextBlock Text="RFID Management System v1.0"
                           Foreground="Gray"
                           HorizontalAlignment="Right"/>

			</DockPanel>

		</Border>

	</Grid>
</Window>