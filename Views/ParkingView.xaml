<UserControl x:Class="QuanLyGiuXe.Views.ParkingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyGiuXe.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="Transparent">
    
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LANE 1 (LEFT) -->
        <Border Grid.Column="0" Style="{StaticResource EnterpriseCardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{Binding DataContext.Lane1Color, RelativeSource={RelativeSource AncestorType=Window}}" Padding="15,10" CornerRadius="4,4,0,0" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding DataContext.Lane1Title, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Grid Grid.Row="1" Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Camera 1 & Snap 1 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="Black" CornerRadius="4" Margin="0,0,4,0">
                            <Grid>
                                <Image x:Name="CameraVao1" Stretch="UniformToFill"/>
                                <Border Background="#80000000" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="CAM 1 - LIVE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Background="Black" CornerRadius="4" Margin="4,0,0,0">
                            <Grid>
                                <Image Source="{Binding DataContext.AnhChupVao1, RelativeSource={RelativeSource AncestorType=Window}}" Stretch="UniformToFill"/>
                                <Border Background="#8027AE60" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="SNAP 1" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Camera 2 & Snap 2 -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="Black" CornerRadius="4" Margin="0,0,4,0">
                            <Grid>
                                <Image x:Name="CameraVao2" Stretch="UniformToFill"/>
                                <Border Background="#80000000" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="CAM 2 - LIVE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Background="Black" CornerRadius="4" Margin="4,0,0,0">
                            <Grid>
                                <Image Source="{Binding DataContext.AnhChupVao2, RelativeSource={RelativeSource AncestorType=Window}}" Stretch="UniformToFill"/>
                                <Border Background="#8027AE60" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="SNAP 2" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <Border Background="{StaticResource BgLightBrush}" Padding="15" CornerRadius="4">
                            <StackPanel>
                                 <TextBlock Text="{Binding DataContext.Lane1InfoLabel, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource SubTitleStyle}" Margin="0,0,0,5"/>
                                 <Border Background="#1A27AE60" BorderBrush="#3327AE60" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Left" Padding="6,2" Margin="0,0,0,10">
                                     <StackPanel Orientation="Horizontal">
                                         <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2zm-1,14.5v-9l6,4.5-6,4.5z" Fill="#27AE60" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                         <TextBlock Text="{Binding DataContext.Lane1ReaderMappingDisplay, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Biển số:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding DataContext.Lane1BienSo, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="24" FontWeight="Bold" Foreground="{Binding DataContext.Lane1Color, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        
                                        <StackPanel Visibility="{Binding DataContext.Lane1TimeVisibility, RelativeSource={RelativeSource AncestorType=Window}}" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding DataContext.Lane1ThoiGianVao, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text=" | " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding DataContext.Lane1ThoiGianTrongBai, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                        
                                        <TextBlock Visibility="{Binding DataContext.IsLane1Inbound, Converter={StaticResource BoolToVis}}" Text="{Binding DataContext.Lane1UID, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='{}UID: {0}'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{Binding DataContext.Lane1ButtonText, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource ModernButton}" Click="OpenGateIn_Click" Width="120" VerticalAlignment="Top"/>
                                </Grid>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DataContext.Lane1TrangThai, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Visibility="{Binding DataContext.Lane1FeeVisibility, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding DataContext.Lane1Tien, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='{}PHÍ: {0}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Stretch" />

        <!-- LANE 2 (RIGHT) -->
        <Border Grid.Column="2" Style="{StaticResource EnterpriseCardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{Binding DataContext.Lane2Color, RelativeSource={RelativeSource AncestorType=Window}}" Padding="15,10" CornerRadius="4,4,0,0" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding DataContext.Lane2Title, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold" Foreground="White"/>
                </Border>

                <Grid Grid.Row="1" Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Camera 1 & Snap 1 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="Black" CornerRadius="4" Margin="0,0,4,0">
                            <Grid>
                                <Image x:Name="CameraRa1" Stretch="UniformToFill"/>
                                <Border Background="#80000000" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="CAM 1 - LIVE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Background="Black" CornerRadius="4" Margin="4,0,0,0">
                            <Grid>
                                <Image Source="{Binding DataContext.AnhChupRa1, RelativeSource={RelativeSource AncestorType=Window}}" Stretch="UniformToFill"/>
                                <Border Background="#80E74C3C" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="SNAP 1" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Camera 2 & Snap 2 -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="Black" CornerRadius="4" Margin="0,0,4,0">
                            <Grid>
                                <Image x:Name="CameraRa2" Stretch="UniformToFill"/>
                                <Border Background="#80000000" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="CAM 2 - LIVE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Background="Black" CornerRadius="4" Margin="4,0,0,0">
                            <Grid>
                                <Image Source="{Binding DataContext.AnhChupRa2, RelativeSource={RelativeSource AncestorType=Window}}" Stretch="UniformToFill"/>
                                <Border Background="#80E74C3C" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="5,2" Margin="5">
                                    <TextBlock Text="SNAP 2" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <Border Background="{StaticResource BgLightBrush}" Padding="15" CornerRadius="4">
                            <StackPanel>
                                 <TextBlock Text="{Binding DataContext.Lane2InfoLabel, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource SubTitleStyle}" Margin="0,0,0,5"/>
                                 <Border Background="#1A27AE60" BorderBrush="#3327AE60" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Left" Padding="6,2" Margin="0,0,0,10">
                                     <StackPanel Orientation="Horizontal">
                                         <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2zm-1,14.5v-9l6,4.5-6,4.5z" Fill="#27AE60" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                         <TextBlock Text="{Binding DataContext.Lane2ReaderMappingDisplay, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Biển số:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding DataContext.Lane2BienSo, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="24" FontWeight="Bold" Foreground="{Binding DataContext.Lane2Color, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        
                                        <StackPanel Visibility="{Binding DataContext.Lane2TimeVisibility, RelativeSource={RelativeSource AncestorType=Window}}" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding DataContext.Lane2ThoiGianVao, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text=" | " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding DataContext.Lane2ThoiGianTrongBai, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>

                                        <TextBlock Visibility="{Binding DataContext.IsLane2Inbound, Converter={StaticResource BoolToVis}}" Text="{Binding DataContext.Lane2UID, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='{}UID: {0}'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{Binding DataContext.Lane2ButtonText, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource ModernButton}" Click="OpenGateOut_Click" Width="120" VerticalAlignment="Top"/>
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DataContext.Lane2TrangThai, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Visibility="{Binding DataContext.Lane2FeeVisibility, RelativeSource={RelativeSource AncestorType=Window}}" Text="{Binding DataContext.Lane2Tien, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='{}PHÍ: {0}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
