<Window x:Class="QuanLyGiuXe.Views.CameraSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Cài đặt Camera"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chọn camera cho mỗi vị trí"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Vào Toàn cảnh -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟢 Vào – Toàn cảnh:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#27AE60" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbVaoToanCanh" Grid.Column="1" Height="28" FontSize="12"/>
        </Grid>

        <!-- Vào Biển số -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟢 Vào – Biển số:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#27AE60" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbVaoBienSo" Grid.Column="1" Height="28" FontSize="12"/>
        </Grid>

        <!-- Ra Toàn cảnh -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🔴 Ra – Toàn cảnh:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#E74C3C" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbRaToanCanh" Grid.Column="1" Height="28" FontSize="12"/>
        </Grid>

        <!-- Ra Biển số -->
        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🔴 Ra – Biển số:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#E74C3C" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbRaBienSo" Grid.Column="1" Height="28" FontSize="12"/>
        </Grid>

        <TextBlock Grid.Row="5" x:Name="txtCameraCount"
                   FontSize="12" Foreground="#888" Margin="0,5,0,0"/>

        <TextBlock Grid.Row="6"
                   Text="💡 Chọn &quot;(Tự động)&quot; = camera theo thứ tự mặc định.&#x0a;Cần khởi động lại app sau khi thay đổi."
                   FontSize="12" Foreground="#666" TextWrapping="Wrap"
                   VerticalAlignment="Bottom" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Lưu" Width="100" Height="32"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"
                    Click="Save_Click" Margin="0,0,10,0"/>
            <Button Content="Đóng" Width="80" Height="32" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
