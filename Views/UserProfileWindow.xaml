<Window x:Class="QuanLyGiuXe.Views.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin cá nhân"
        Height="520"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA">

	<Grid>

		<Border Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="20">

			<StackPanel>

				<!-- Header -->
				<TextBlock Text="Thông tin cá nhân"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,25"/>

				<!-- Avatar -->
				<Border Width="90"
                        Height="90"
                        CornerRadius="45"
                        Background="#3498DB"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,25">

					<TextBlock Text="👤"
                               FontSize="40"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
				</Border>

				<!-- Tên -->
				<TextBlock Text="Họ tên"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

				<TextBox Height="38"
                         Margin="0,0,0,15"
                         Padding="10"
                         Text="{Binding Ten}"/>

				<!-- Username -->
				<TextBlock Text="Username"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

				<TextBox Height="38"
                         Margin="0,0,0,15"
                         Padding="10"
                         Text="{Binding Username}"/>

				<!-- Buttons -->
				<Grid Margin="0,25,0,0">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<!-- Save -->
					<Button Grid.Column="0"
                            Height="42"
                            Content="💾 Lưu thay đổi"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
							Command="{Binding SaveCommand}"/>

					<!-- Cancel -->
					<Button Grid.Column="2"
                            Height="42"
                            Content="❌ Đóng"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click"/>
				</Grid>

			</StackPanel>

		</Border>

	</Grid>
</Window>