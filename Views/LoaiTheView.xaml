<UserControl x:Class="QuanLyGiuXe.Views.LoaiTheView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Tên loại thẻ" Margin="0,0,0,4"/>
                <TextBox Width="220" Text="{Binding TenLoaiThe, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Giá tiền" Margin="0,0,0,4"/>
                <TextBox Width="140" Text="{Binding GiaTien, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Trạng thái" Margin="0,0,0,4"/>
                <TextBox Width="160" Text="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Thêm" Command="{Binding AddCommand}" Width="80" Margin="0,0,6,0"/>
                <Button Content="Sửa" Command="{Binding UpdateCommand}" Width="80" Margin="0,0,6,0"/>
                <Button Content="Xóa" Command="{Binding DeleteCommand}" Width="80" Margin="0,0,6,0"/>
                <Button Content="Load" Command="{Binding LoadCommand}" Width="80" Margin="0,0,6,0"/>
                <Button Content="Clear" Command="{Binding ClearCommand}" Width="80"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Tên loại thẻ" Binding="{Binding TenLoaiThe}" Width="*"/>
                <DataGridTextColumn Header="Giá tiền" Binding="{Binding GiaTien, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
