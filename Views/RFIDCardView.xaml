<UserControl x:Class="QuanLyGiuXe.Views.RFIDCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels">
    <UserControl.DataContext>
        <vm:RFIDCardViewModel />
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="UID" Margin="0,0,0,4"/>
                <TextBox Width="220" Text="{Binding UID, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Biển số" Margin="0,0,0,4"/>
                <TextBox Width="160" Text="{Binding BienSo, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Loại vé Id" Margin="0,0,0,4"/>
                <TextBox Width="100" Text="{Binding LoaiVeId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Loại xe Id" Margin="0,0,0,4"/>
                <TextBox Width="100" Text="{Binding LoaiXeId, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                <TextBlock Text="Trạng thái" Margin="0,0,0,4"/>
                <TextBox Width="140" Text="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Thêm" Command="{Binding AddCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="Sửa" Command="{Binding UpdateCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="Xóa" Command="{Binding DeleteCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="Load" Command="{Binding LoadCommand}" Width="90" Margin="0,0,6,0"/>
                <Button Content="Clear" Command="{Binding ClearCommand}" Width="90"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="UID" Binding="{Binding UID}" Width="150"/>
                <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120"/>
                <DataGridTextColumn Header="Loại vé Id" Binding="{Binding LoaiVeId}" Width="100"/>
                <DataGridTextColumn Header="Loại xe Id" Binding="{Binding LoaiXeId}" Width="100"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
                <DataGridTextColumn Header="Ngày tạo" Binding="{Binding NgayTao, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
