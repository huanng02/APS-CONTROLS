<UserControl x:Class="QuanLyGiuXe.Views.RFIDCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>


        <!-- Button style -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab style -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:RFIDCardViewModel />
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="10" Padding="12" 
                BorderBrush="#E5E7EB" BorderThickness="1">

            <TabControl ItemsSource="{Binding Tabs}" 
                        SelectedItem="{Binding SelectedTab, Mode=TwoWay}">

                <!-- Tab Header -->
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <!-- Tab Content -->
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <DockPanel>

                            <!-- Toolbar -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Button Content="➕ Thêm"
                                        Command="{Binding DataContext.AddCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Visibility="{Binding DataContext.CanAdd, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

                                <Button Content="🗑 Selected"
                                        Background="#EF4444"
                                        Command="{Binding DataContext.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                                <Button Content="⚠ Delete All"
                                        Background="#DC2626"
                                        Command="{Binding DataContext.DeleteAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                                <Button Content="🔄 Load"
                                        Background="#10B981"
                                        Command="{Binding DataContext.LoadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                                <Button Content="📤 Export"
                                        Background="#6366F1"
                                        Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                                <Button Content="📥 Import Excel"
                                        Background="#F59E0B"
                                        Click="OpenImportExport_Click"/>

                                <Button Content="📄 Template"
                                        Background="#6B7280"
                                        Command="{Binding DataContext.DownloadTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </StackPanel>

                            <!-- DataGrid -->
                            <DataGrid ItemsSource="{Binding Items}"
                                      SelectedItem="{Binding DataContext.SelectedItem, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">

                                <DataGrid.Columns>

                                    <DataGridTemplateColumn Width="40">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                                    <DataGridTextColumn Header="Card UID" Binding="{Binding CardUID}" Width="150"/>
                                    <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120"/>
                                    <DataGridTextColumn Header="Loại vé" Binding="{Binding LoaiVe}" Width="120"/>
                                    <DataGridTextColumn Header="Loại xe" Binding="{Binding LoaiXe}" Width="120"/>
                                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>

                                    <DataGridTemplateColumn Header="Thao tác" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="Sửa"
                                                            Background="#3B82F6"
                                                            Command="{Binding DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />

                                                    <Button Content="Xóa"
                                                            Background="#EF4444"
                                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>

                        </DockPanel>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

        </Border>
    </Grid>
</UserControl>