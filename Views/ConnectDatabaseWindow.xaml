<Window x:Class="QuanLyGiuXe.Views.ConnectDatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kết Nối Cơ Sở Dữ Liệu" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F2F5">
    <Window.Resources>
        <!-- Converter for Status Color -->
        <Style TargetType="TextBlock" x:Key="StatusTextStyle">
            <Setter Property="Foreground" Value="#E74C3C" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Foreground" Value="#27AE60" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CẤU HÌNH KẾT NỐI SQL SERVER" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="IP Server:" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <TextBox Grid.Column="1" Text="{Binding ServerIP, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Grid.Row="1" Text="Port:" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0">
                <ComboBoxItem Content="1433"/>
            </ComboBox>

            <TextBlock Grid.Row="2" Text="Database:" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Grid.Row="3" Text="Username:" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Grid.Row="4" Text="Password:" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="txtPassword" PasswordChanged="txtPassword_PasswordChanged" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center" Padding="5,0"/>
        </Grid>

        <!-- Status & Loading -->
        <StackPanel Grid.Row="3" Margin="0,15,0,15">
            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,10">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Ping Server" Command="{Binding PingServerCommand}" Width="100"/>
            <Button Content="Test Connection" Command="{Binding TestConnectionCommand}" Width="120" Background="#3498DB"/>
        </StackPanel>

        <Button Grid.Row="5" Content="Connect" Command="{Binding ConnectCommand}" Height="35" Margin="0,10,0,0" Background="#27AE60" FontSize="14"/>
    </Grid>
</Window>
