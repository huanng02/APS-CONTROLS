<Window x:Class="QuanLyGiuXe.Views.ConnectDatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL SERVER CONNECTION" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgLightBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="StatusTextStyle">
            <Setter Property="Foreground" Value="{StaticResource APSRedBrush}" />
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Border Style="{StaticResource EnterpriseCardBorder}" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="DATABASE CONFIGURATION" Style="{StaticResource Heading1Style}" Foreground="{StaticResource APSBlueBrush}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Form -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SERVER ADDRESS" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding ServerIP, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="1" Text="NETWORK PORT" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernComboBox}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Height="36" Margin="0,0,0,15">
                        <ComboBoxItem Content="1433"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Text="DATABASE NAME" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="3" Text="USERNAME" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="4" Text="PASSWORD" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="txtPassword_PasswordChanged" Height="36" Margin="0,0,0,15"/>
                </Grid>

                <!-- Status & Loading -->
                <StackPanel Grid.Row="2" Margin="0,10">
                    <ProgressBar IsIndeterminate="True" Height="2" Background="Transparent" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,10">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="PING SERVER" Style="{StaticResource ModernOutlineButton}" Command="{Binding PingServerCommand}" Height="40"/>
                    <Button Grid.Column="2" Content="TEST LINK" Style="{StaticResource ModernOutlineButton}" Command="{Binding TestConnectionCommand}" Height="40"/>
                </Grid>

                <Button Grid.Row="4" Content="ESTABLISH CONNECTION" Style="{StaticResource ModernButton}" Command="{Binding ConnectCommand}" Height="45" Margin="0,15,0,0" Background="{StaticResource SuccessBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

