<Window x:Class="QuanLyGiuXe.Views.SQLQueryToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        mc:Ignorable="d"
        Title="ADMINISTRATIVE SQL WORKBENCH" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgLightBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource EnterpriseCardBorder}" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource APSBlueBrush}" CornerRadius="4" Padding="8" Margin="0,0,15,0">
                    <TextBlock Text="⚡" Foreground="White" FontSize="18"/>
                </Border>
                <TextBlock Text="SQL QUERY CONSOLE" Style="{StaticResource Heading1Style}" Foreground="{StaticResource APSBlueBrush}"/>
            </StackPanel>
        </Border>

        <!-- Editor Section -->
        <Border Grid.Row="1" Style="{StaticResource EnterpriseCardBorder}" Padding="10">
            <TextBox Text="{Binding SqlText, UpdateSourceTrigger=PropertyChanged}" 
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="15"
                     Padding="15" VerticalScrollBarVisibility="Auto" 
                     BorderThickness="0" Background="Transparent"
                     Foreground="{StaticResource APSBlueBrush}">
                <TextBox.InputBindings>
                    <KeyBinding Key="F5" Command="{Binding ExecuteCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="2" Style="{StaticResource EnterpriseCardBorder}" Padding="15" Margin="0,15">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding ExecuteCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="180" Height="42">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,10,0"/>
                        <TextBlock Text="EXECUTE (F5)" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                
                <Button Content="🧹 CLEAR EDITOR" Command="{Binding ClearCommand}" Style="{StaticResource ModernOutlineButton}" Width="160" Height="42" Margin="15,0,0,0"/>
                
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,5"/>
                
                <TextBlock Text="AWAITING INPUT" VerticalAlignment="Center" Style="{StaticResource SubTitleStyle}" Opacity="0.5"/>
            </StackPanel>
        </Border>

        <!-- Error Panel -->
        <Border Grid.Row="3" Background="#FFF1F0" BorderBrush="{StaticResource APSRedBrush}" BorderThickness="1" 
                Padding="15" CornerRadius="8" Margin="0,0,0,20"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Top"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource APSRedBrush}" FontWeight="Bold" 
                           FontSize="13" TextWrapping="Wrap" MaxWidth="1000"/>
            </StackPanel>
        </Border>

        <!-- Result Grid -->
        <Border Grid.Row="4" Style="{StaticResource EnterpriseCardBorder}" Padding="0">
            <DataGrid ItemsSource="{Binding QueryResult}" AutoGenerateColumns="True" IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}">
            </DataGrid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="5" Background="{StaticResource BgLightBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="15,8" Margin="-25,10,-25,-25">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource APSBlueBrush}" FontSize="12" FontWeight="Bold"/>
                <TextBlock Text="ADMIN MODE" HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>

