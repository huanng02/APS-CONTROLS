<Window x:Class="QuanLyGiuXe.Views.VehicleDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Xe" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="📋 CHI TIẾT XE" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
            
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Biển Số" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtBienSo" Text="" FontSize="20" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Thời Gian Vào" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtThoiGianVao" Text="" FontSize="14" Foreground="#333" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Thời Gian Ra" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtThoiGianRa" Text="" FontSize="14" Foreground="#333" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Thời Gian Gửi" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtThoiGianGui" Text="" FontSize="14" Foreground="#333" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Tiền Phí" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtTien" Text="" FontSize="18" FontWeight="Bold" Foreground="#28A745" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>
            
            <Button Content="✖ Đóng" Click="BtnClose_Click" 
                    Background="#6C757D" Foreground="White" 
                    Height="40" FontSize="14" FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
