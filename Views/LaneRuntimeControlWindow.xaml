<Window x:Class="QuanLyGiuXe.Views.LaneRuntimeControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Điều khiển Làn (Dynamic Lane Runtime Control)" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" Background="#F4F6F8"
        Topmost="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#143A7D" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="LANE RUNTIME CONTROL PANEL" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="Thao tác đảo chiều, bảo trì hoặc mở khẩn cấp tại đây." Foreground="#B0C4DE" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Lanes Dashboard -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Lanes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Margin="8" Padding="15">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{Binding LaneId, StringFormat='LÀN SỐ {0}'}" FontWeight="Bold" FontSize="18" Foreground="#333"/>
                                <Border HorizontalAlignment="Right" Background="{Binding StatusColor}" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="{Binding CurrentDirection}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                            
                            <StackPanel Margin="0,15,0,0" Orientation="Horizontal">
                                <TextBlock Text="Trạng thái xử lý: " Foreground="#666"/>
                                <TextBlock Text="{Binding IsLocked, StringFormat='{}{0}'}" 
                                           FontWeight="Bold" 
                                           Foreground="{Binding StatusColor}"/>
                            </StackPanel>
                            
                            <!-- Control Buttons -->
                            <TextBlock Text="Điều khiển luồng (Direction Switch):" Margin="0,20,0,10" Foreground="#666" FontWeight="SemiBold"/>
                            
                            <UniformGrid Columns="2" Rows="2">
                                <Button Content="Luồng VÀO (IN)" Command="{Binding SetInboundCommand}" CommandParameter="{Binding LaneId}"
                                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,5,5" Height="40">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Content="Luồng RA (OUT)" Command="{Binding SetOutboundCommand}" CommandParameter="{Binding LaneId}"
                                        Background="#2196F3" Foreground="White" FontWeight="Bold" Margin="5,0,0,5" Height="40">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Content="BẢO TRÌ" Command="{Binding SetMaintenanceCommand}" CommandParameter="{Binding LaneId}"
                                        Background="#FF9800" Foreground="White" FontWeight="Bold" Margin="0,5,5,0" Height="40">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="🚨 MỞ KHẨN CẤP" Command="{Binding EmergencyOpenCommand}" CommandParameter="{Binding LaneId}"
                                        Background="#F44336" Foreground="White" FontWeight="Bold" Margin="5,5,0,0" Height="40">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</Window>
