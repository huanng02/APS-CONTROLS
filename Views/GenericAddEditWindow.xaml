<Window x:Class="QuanLyGiuXe.Views.GenericAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CHỈNH SỬA THÔNG TIN" 
        SizeToContent="Height" 
        Width="480" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource APSBlueBrush}" CornerRadius="12,12,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏️" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="CHỈNH SỬA THÔNG TIN" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="Vui lòng nhập đầy đủ các thông tin bên dưới" Foreground="#B0C4DE" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource ModernOutlineButton}" BorderThickness="0" Foreground="White"
                            Width="30" Height="30" Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" MaxHeight="500" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FieldsPanel" Margin="30,20" />
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgLightBrush}" CornerRadius="0,0,12,12" Padding="20,15" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="HỦY BỎ" Width="100" Height="38" Margin="0,0,10,0" 
                            Style="{StaticResource ModernOutlineButton}" Click="Cancel_Click"/>
                    <Button Content="LƯU THÔNG TIN" Width="140" Height="38" 
                            Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" 
                            Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
