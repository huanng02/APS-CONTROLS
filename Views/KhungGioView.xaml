<UserControl x:Class="QuanLyGiuXe.Views.KhungGioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- DataContext is set in code-behind to avoid XAML type resolution issues at design time -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Quản lý khung giờ" FontSize="16" FontWeight="Bold" />

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="30" IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên khung" Binding="{Binding TenKhungGio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridTemplateColumn Header="Gio bat dau" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GioBatDauText}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding GioBatDauText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Gio ket thuc" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GioKetThucText}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding GioKetThucText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Header="QuaDem" Binding="{Binding QuaDem, Mode=OneWay}" IsReadOnly="True" Width="80" />
                <DataGridCheckBoxColumn Header="TrangThai" Binding="{Binding TrangThai, Mode=TwoWay}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Grid.Row="2" Margin="0,8,0,0">
            <Button Content="Add" Command="{Binding AddCommand}" Width="80" Margin="4" />
            <Button Content="Update" Command="{Binding UpdateCommand}" Width="80" Margin="4" />
            <Button Content="Delete" Command="{Binding DeleteCommand}" Width="80" Margin="4" />
            <TextBlock Text="{Binding StatusMessage}" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>