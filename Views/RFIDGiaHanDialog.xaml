<Window x:Class="QuanLyGiuXe.Views.RFIDGiaHanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RFID CARD EXTENSION" Height="320" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource BgLightBrush}">
    <Grid Margin="25">
        <Border Style="{StaticResource EnterpriseCardBorder}" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="MEMBERSHIP EXTENSION" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,20"/>

                <!-- Info Section -->
                <Border Grid.Row="1" Background="{StaticResource BgLightBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{Binding CardInfo}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding PlateInfo}" Style="{StaticResource SubTitleStyle}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Input Section -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="EXTENSION PERIOD (MONTHS)" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtMonths" Style="{StaticResource ModernTextBox}" Height="40" Text="1" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="txtError" Foreground="{StaticResource APSRedBrush}" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="CANCEL" Style="{StaticResource ModernOutlineButton}" Width="100" Height="38" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                    <Button Content="CONFIRM EXTENSION" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="180" Height="38" Click="BtnOk_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

