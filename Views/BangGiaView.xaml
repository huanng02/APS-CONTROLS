<UserControl x:Class="QuanLyGiuXe.Views.BangGiaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F5F7F9">

    <UserControl.DataContext>
        <vm:BangGiaManagementViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="5" Height="25" Background="#2196F3" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="QUẢN LÝ BẢNG GIÁ" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: DATA TABLE ================= -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Danh sách bảng giá hiện có" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              RowHeight="40"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#FAFAFA"
                              SelectionMode="Single">
                        
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="Foreground" Value="#34495E"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTemplateColumn Header="Loại Xe" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LoaiXe}" VerticalAlignment="Center" FontWeight="Medium" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Loại Vé" Binding="{Binding LoaiVe}" Width="100"/>
                            <DataGridTextColumn Header="Số khung" Binding="{Binding KhungGiaCount}" Width="80"/>
                            <DataGridTextColumn Header="Giá tháng" Binding="{Binding GiaThang, StringFormat={}{0:N0} đ}" Width="110"/>
                            <DataGridTextColumn Header="Giá theo khung" Binding="{Binding GiaTheoKhungDisplay}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ================= RIGHT: CONFIG & TOOLS ================= -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <!-- INFO CARD -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="CẤU HÌNH CHI TIẾT" FontSize="14" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="Loại Xe" Style="{StaticResource FormLabel}"/>
                                    <ComboBox ItemsSource="{Binding LoaiXeList}"
                                              DisplayMemberPath="TenLoai"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding EditingItem.LoaiXeId}"
                                              Height="32" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Loại Vé" Style="{StaticResource FormLabel}"/>
                                    <ComboBox ItemsSource="{Binding LoaiVeList}"
                                              DisplayMemberPath="TenLoai"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedLoaiVeId}"
                                              Height="32" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Giá vé tháng (đ)" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding GiaThangText}"
                                     IsEnabled="{Binding IsThang}"
                                     Height="32" VerticalContentAlignment="Center" Padding="5,0"
                                     FontSize="14" FontWeight="SemiBold"/>

                            <!-- KHUNG GIỜ SECTION -->
                            <StackPanel Visibility="{Binding IsVangLai, Converter={StaticResource BoolToVis}}" Margin="0,15,0,0">
                                <Grid Margin="0,0,0,5">
                                    <TextBlock Text="BẢNG GIÁ KHUNG GIỜ" FontSize="13" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center"/>
                                    <Button x:Name="BtnManageKhungGio" Content="⚙ Cấu hình khung" HorizontalAlignment="Right" 
                                            Background="Transparent" Foreground="#2196F3" BorderThickness="0" 
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"/>
                                </Grid>
                                
                                <DataGrid ItemsSource="{Binding KhungGiaItems}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          HeadersVisibility="Column" IsReadOnly="False"
                                          RowHeight="32" BorderBrush="#EEEEEE" BorderThickness="1"
                                          Background="#FAFAFA" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Khung" Binding="{Binding TenKhungGio}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="Thời gian" Binding="{Binding DisplayTime}" IsReadOnly="True" Width="1.2*"/>
                                        <DataGridTextColumn Header="Giá (đ)" Binding="{Binding GiaTien, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Margin" Value="0,0,5,0" />
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Border Background="#FFF9C4" CornerRadius="4" Padding="10" Margin="0,15,0,0"
                                    Visibility="{Binding IsThang, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="ℹ Vé tháng áp dụng mức giá cố định, không dùng khung giờ." 
                                           FontSize="11" FontStyle="Italic" Foreground="#F57F17" TextWrapping="Wrap"/>
                            </Border>

                            <!-- ACTIONS -->
                            <UniformGrid Columns="2" Margin="0,20,0,0">
                                <Button Content="➕ Thêm mới" Command="{Binding AddCommand}" Style="{StaticResource ModernButton}" Background="#4CAF50" Margin="0,0,5,5"/>
                                <Button Content="💾 Cập nhật" Command="{Binding UpdateCommand}" Style="{StaticResource ModernButton}" Background="#2196F3" Margin="5,0,0,5"/>
                                <Button Content="🗑 Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource ModernButton}" Background="#F44336" Margin="0,5,5,0"/>
                                <Button Content="🧹 Làm mới" Command="{Binding ClearCommand}" Style="{StaticResource ModernButton}" Background="#78909C" Margin="5,5,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- TEST PRICE CARD -->
                    <Border Style="{StaticResource CardBorder}" Margin="5,10,5,20">
                        <StackPanel>
                            <TextBlock Text="CÔNG CỤ KIỂM TRA GIÁ" FontSize="14" FontWeight="Bold" Foreground="#673AB7" Margin="0,0,0,15"/>

                            <TextBlock Text="Thời gian xe VÀO" Style="{StaticResource FormLabel}" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding ThoiGianVaoDate}" Height="32" VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                    <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianVaoHour}" Width="50" Height="32"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianVaoMinute}" Width="50" Height="32"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Seconds}" SelectedItem="{Binding ThoiGianVaoSecond}" Width="50" Height="32"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Thời gian xe RA" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding ThoiGianRaDate}" Height="32" VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                    <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianRaHour}" Width="50" Height="32"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianRaMinute}" Width="50" Height="32"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Seconds}" SelectedItem="{Binding ThoiGianRaSecond}" Width="50" Height="32"/>
                                </StackPanel>
                            </Grid>

                            <!-- RESULT PANEL -->
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="15" Margin="0,20,0,0" BorderBrush="#A5D6A7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ƯỚC TÍNH CHI PHÍ" FontSize="11" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding ResultText}" FontSize="15" FontWeight="Bold" Foreground="#1B5E20" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>