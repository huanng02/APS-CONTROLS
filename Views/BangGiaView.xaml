<UserControl x:Class="QuanLyGiuXe.Views.BangGiaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <UserControl.DataContext>
        <vm:BangGiaManagementViewModel />
    </UserControl.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Bảng giá - Quản lý" FontSize="18" FontWeight="Bold" />

        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgBangGia" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="36" Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Loại Xe" Binding="{Binding LoaiXe}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Loại Vé" Binding="{Binding LoaiVe}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Giá ban ngày" Binding="{Binding GiaBanNgay, StringFormat=N2}" Width="120" />
                    <DataGridTextColumn Header="Giá qua đêm" Binding="{Binding GiaQuaDem, StringFormat=N2}" Width="120" />
                    <DataGridTextColumn Header="Giá tháng" Binding="{Binding GiaThang, StringFormat=N2}" Width="120" />
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="8">
                <StackPanel>
                    <TextBlock Text="Thao tác" FontWeight="Bold" Margin="0,0,0,8" />

                    <TextBlock Text="Loại Xe" />
                    <ComboBox ItemsSource="{Binding LoaiXeList}" DisplayMemberPath="TenLoai" SelectedValuePath="Id" SelectedValue="{Binding EditingItem.LoaiXeId, Mode=TwoWay}" />

                    <TextBlock Text="Loại Vé" Margin="0,8,0,0" />
                    <!-- Bind SelectedValue to SelectedLoaiVeId (int) to avoid object identity issues -->
                    <ComboBox ItemsSource="{Binding LoaiVeList}" DisplayMemberPath="TenLoai"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedLoaiVeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Giá ban ngày" Margin="0,8,0,0" />
                    <TextBox Text="{Binding GiaBanNgayText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsVangLai}" />

                    <TextBlock Text="Giá qua đêm" Margin="0,8,0,0" />
                    <TextBox Text="{Binding GiaQuaDemText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsVangLai}" />

                    <TextBlock Text="Giá tháng" Margin="0,8,0,0" />
                    <TextBox Text="{Binding GiaThangText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsThang}" />

                    <TextBlock Text="Trạng thái" Margin="0,8,0,0" />
                    <ComboBox SelectedValue="{Binding EditingItem.TrangThai, Mode=TwoWay}" SelectedValuePath="." >
                        <sys:String>Active</sys:String>
                        <sys:String>Inactive</sys:String>
                        <sys:String>Disabled</sys:String>
                    </ComboBox>

                    <Separator Margin="0,8,0,8" />
                    <TextBlock Text="Tính thời gian và chi phí" FontWeight="Bold" Margin="0,8,0,8" />
                    <TextBlock Text="Thời gian vào" />
                    <StackPanel Orientation="Horizontal">
                        <DatePicker SelectedDate="{Binding ThoiGianVaoDate, Mode=TwoWay}" />
                        <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianVaoHour, Mode=TwoWay}" Width="60" Margin="6,0,0,0" />
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0" />
                        <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianVaoMinute, Mode=TwoWay}" Width="60" />
                    </StackPanel>
                    <TextBlock Text="Thời gian ra" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal">
                        <DatePicker SelectedDate="{Binding ThoiGianRaDate, Mode=TwoWay}" />
                        <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianRaHour, Mode=TwoWay}" Width="60" Margin="6,0,0,0" />
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0" />
                        <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianRaMinute, Mode=TwoWay}" Width="60" />
                    </StackPanel>

                    <TextBlock Text="Kết quả" FontWeight="Bold" Margin="0,8,0,4" />
                    <TextBlock Text="{Binding ResultText}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Add" Width="80" Margin="4" Command="{Binding AddCommand}" />
                        <Button Content="Update" Width="80" Margin="4" Command="{Binding UpdateCommand}" />
                        <Button Content="Delete" Width="80" Margin="4" Command="{Binding DeleteCommand}" />
                        <Button Content="Clear" Width="80" Margin="4" Command="{Binding ClearCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>