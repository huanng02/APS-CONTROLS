<UserControl x:Class="QuanLyGiuXe.Views.BangGiaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource BgLightBrush}">

    <UserControl.DataContext>
        <vm:BangGiaManagementViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="{StaticResource APSBlueBrush}" CornerRadius="4" Padding="10" Margin="0,0,15,0">
                <TextBlock Text="💰" FontSize="20" Foreground="White" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="PRICING MANAGEMENT" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: DATA TABLE ================= -->
            <Border Style="{StaticResource EnterpriseCardBorder}" Margin="0,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Pricing List" Style="{StaticResource SubTitleStyle}" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              Style="{StaticResource ModernDataGrid}">
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTemplateColumn Header="VEHICLE" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LoaiXe}" VerticalAlignment="Center" FontWeight="Medium" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="TICKET" Binding="{Binding LoaiVe}" Width="100"/>
                            <DataGridTextColumn Header="FRAMES" Binding="{Binding KhungGiaCount}" Width="80"/>
                            <DataGridTextColumn Header="MONTHLY" Binding="{Binding GiaThang, StringFormat={}{0:N0} đ}" Width="110"/>
                            <DataGridTextColumn Header="PRICE DETAILS" Binding="{Binding GiaTheoKhungDisplay}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ================= RIGHT: CONFIG & TOOLS ================= -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <!-- INFO CARD -->
                    <Border Style="{StaticResource EnterpriseCardBorder}" Padding="15">
                        <StackPanel>
                            <TextBlock Text="CONFIGURATION DETAILS" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="Vehicle Type" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding LoaiXeList}"
                                              Style="{StaticResource ModernComboBox}"
                                              DisplayMemberPath="TenLoai"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding EditingItem.LoaiXeId}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Ticket Type" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding LoaiVeList}"
                                              Style="{StaticResource ModernComboBox}"
                                              DisplayMemberPath="TenLoai"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedLoaiVeId}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Monthly Price (VNĐ)" Style="{StaticResource BaseTextBlockStyle}" Margin="0,15,0,5"/>
                            <TextBox Text="{Binding GiaThangText}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsEnabled="{Binding IsThang}"/>

                            <!-- KHUNG GIỜ SECTION -->
                            <StackPanel Visibility="{Binding IsVangLai, Converter={StaticResource BoolToVis}}" Margin="0,20,0,0">
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="HOURLY RATE TABLE" Style="{StaticResource SubTitleStyle}" VerticalAlignment="Center"/>
                                    <Button x:Name="BtnManageKhungGio" Content="Manage Frames" HorizontalAlignment="Right" 
                                            Background="Transparent" Foreground="{StaticResource APSBlueBrush}" BorderThickness="0" 
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"/>
                                </Grid>
                                
                                <DataGrid ItemsSource="{Binding KhungGiaItems}"
                                          Style="{StaticResource ModernDataGrid}"
                                          Height="150" HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FRAME" Binding="{Binding TenKhungGio}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="TIME" Binding="{Binding DisplayTime}" IsReadOnly="True" Width="1.2*"/>
                                        <DataGridTextColumn Header="FEE (đ)" Binding="{Binding GiaTien, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Border Background="{StaticResource BgLightBrush}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1,0,0,0" Padding="10" Margin="0,15,0,0"
                                    Visibility="{Binding IsThang, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="ℹ Monthly tickets use a fixed rate and do not use hourly frames." 
                                           FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </Border>

                            <!-- ACTIONS -->
                            <UniformGrid Columns="2" Margin="0,20,0,0">
                                <Button Content="Add New" Command="{Binding AddCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Margin="0,0,5,5"/>
                                <Button Content="Update" Command="{Binding UpdateCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource APSBlueBrush}" Margin="5,0,0,5"/>
                                <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,5,5,0"/>
                                <Button Content="Clear" Command="{Binding ClearCommand}" Style="{StaticResource ModernOutlineButton}" Margin="5,5,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- TEST PRICE CARD -->
                    <Border Style="{StaticResource EnterpriseCardBorder}" Margin="5,10,5,20" Padding="15">
                        <StackPanel>
                            <TextBlock Text="FEE CALCULATION TEST" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>

                            <TextBlock Text="Entry Time" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding ThoiGianVaoDate}" Height="32" VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                    <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianVaoHour}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianVaoMinute}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Seconds}" SelectedItem="{Binding ThoiGianVaoSecond}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Exit Time" Style="{StaticResource BaseTextBlockStyle}" Margin="15,10,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding ThoiGianRaDate}" Height="32" VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                    <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding ThoiGianRaHour}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding ThoiGianRaMinute}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                    <ComboBox ItemsSource="{Binding Seconds}" SelectedItem="{Binding ThoiGianRaSecond}" Width="50" Style="{StaticResource ModernComboBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- RESULT PANEL -->
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="15" Margin="0,20,0,0" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ESTIMATED COST" Style="{StaticResource SubTitleStyle}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding ResultText}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
