<Window x:Class="QuanLyGiuXe.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast"
        Width="320" Height="72"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="True"
        Focusable="False">

    <Window.Resources>
        <!-- Slide-in từ phải -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <ThicknessAnimation Storyboard.TargetName="RootBorder"
                                Storyboard.TargetProperty="Margin"
                                From="20,0,0,0" To="0,0,0,0"
                                Duration="0:0:0.25">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Fade-out khi đóng -->
        <Storyboard x:Key="FadeOut" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="12"
            Padding="16,0"
            Cursor="Hand"
            MouseLeftButtonDown="Border_Click"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderLightBrush}">
        <Border.Effect>
            <DropShadowEffect Color="#0F172A" Opacity="0.15" BlurRadius="25" ShadowDepth="4"/>
        </Border.Effect>
        <Border.Background>
            <!-- Background set từ code-behind theo ToastType -->
            <SolidColorBrush x:Name="ToastBackground" Color="#FFFFFF"/>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Container -->
            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#F8FAFC" VerticalAlignment="Center" Margin="0,0,14,0">
                <TextBlock x:Name="ToastIcon"
                           Text="✅"
                           FontSize="18"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Message Section -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="ToastMessage"
                           Text="System operation successful"
                           Foreground="{StaticResource APSBlueBrush}"
                           FontSize="13"
                           FontWeight="Bold"
                           FontFamily="Segoe UI Semibold"
                           TextWrapping="Wrap"
                           MaxWidth="220"/>

                <!-- Professional Progress Indicator -->
                <Border Height="4" CornerRadius="2" Background="#F1F5F9" Margin="0,8,0,0">
                    <Border x:Name="CountdownBar"
                            Height="4"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Background="{StaticResource APSBlueBrush}"
                            Width="220">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="CountdownScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0,0</Border.RenderTransformOrigin>
                    </Border>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>

