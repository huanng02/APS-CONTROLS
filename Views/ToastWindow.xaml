<Window x:Class="QuanLyGiuXe.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast"
        Width="320" Height="72"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="True"
        Focusable="False">

    <Window.Resources>
        <!-- Slide-in từ phải -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <ThicknessAnimation Storyboard.TargetName="RootBorder"
                                Storyboard.TargetProperty="Margin"
                                From="20,0,0,0" To="0,0,0,0"
                                Duration="0:0:0.25">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Fade-out khi đóng -->
        <Storyboard x:Key="FadeOut" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="10"
            Padding="14,0"
            Cursor="Hand"
            MouseLeftButtonDown="Border_Click">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3"/>
        </Border.Effect>
        <Border.Background>
            <!-- Background set từ code-behind theo ToastType -->
            <SolidColorBrush x:Name="ToastBackground" Color="#27AE60"/>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <TextBlock x:Name="ToastIcon"
                       Grid.Column="0"
                       Text="✅"
                       FontSize="22"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

            <!-- Message + progress bar -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="ToastMessage"
                           Text="Connected"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           MaxWidth="240"/>

                <!-- Countdown bar -->
                <Border Height="3" CornerRadius="2" Background="#33FFFFFF" Margin="0,6,0,0">
                    <Border x:Name="CountdownBar"
                            Height="3"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Background="White"
                            Width="240">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="CountdownScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0,0</Border.RenderTransformOrigin>
                    </Border>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
