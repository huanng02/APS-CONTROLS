<Window x:Class="QuanLyGiuXe.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Lịch sử xe"
        Height="768"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgLightBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- STATS CARDS ROW -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,15">
            <!-- Total Visits -->
            <Border Style="{StaticResource EnterpriseCardBorder}" Margin="0,0,10,0" BorderBrush="{StaticResource APSBlueBrush}" BorderThickness="0,4,0,0">
                <StackPanel Margin="15">
                    <TextBlock Text="TOTAL VISITS" Style="{StaticResource SubTitleStyle}"/>
                    <TextBlock Text="{Binding TongLuotXe}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Total Revenue -->
            <Border Style="{StaticResource EnterpriseCardBorder}" Margin="5,0,10,0" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="0,4,0,0">
                <StackPanel Margin="15">
                    <TextBlock Text="TOTAL REVENUE (VNĐ)" Style="{StaticResource SubTitleStyle}"/>
                    <TextBlock Text="{Binding TongDoanhThu, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Visits Today -->
            <Border Style="{StaticResource EnterpriseCardBorder}" Margin="5,0,10,0" BorderBrush="{StaticResource WarningBrush}" BorderThickness="0,4,0,0">
                <StackPanel Margin="15">
                    <TextBlock Text="VISITS TODAY" Style="{StaticResource SubTitleStyle}"/>
                    <TextBlock Text="{Binding XeHomNay}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Revenue Today -->
            <Border Style="{StaticResource EnterpriseCardBorder}" Margin="5,0,0,0" BorderBrush="{StaticResource APSRedBrush}" BorderThickness="0,4,0,0">
                <StackPanel Margin="15">
                    <TextBlock Text="REVENUE TODAY" Style="{StaticResource SubTitleStyle}"/>
                    <TextBlock Text="{Binding DoanhThuHomNay, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource APSRedBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- FILTER PANEL -->
        <Border Grid.Row="1" Style="{StaticResource EnterpriseCardBorder}" Margin="0,0,0,15" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Plate No:" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="180" Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}" 
                              Style="{StaticResource ModernTextBox}"/>
                             
                    <TextBlock Text="From:" Style="{StaticResource BaseTextBlockStyle}" Margin="15,0,10,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding TuNgay}" Width="130" Margin="0,0,10,0"/>
                    
                    <TextBlock Text="To:" Style="{StaticResource BaseTextBlockStyle}" Margin="5,0,10,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding DenNgay}" Width="130"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                    <Button Content="Reset" Command="{Binding ResetFilterCommand}" Style="{StaticResource ModernOutlineButton}" Margin="0,0,10,0"/>
                    <Button Content="Export Excel" Command="{Binding ExportExcelCommand}" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABLE -->
        <Border Grid.Row="2" Style="{StaticResource EnterpriseCardBorder}" Padding="1">
            <DataGrid ItemsSource="{Binding DanhSachLichSu}"
                      Style="{StaticResource ModernDataGrid}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Plate Number" />
                        <MenuItem Header="Print Receipt" />
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="PLATE NO" Binding="{Binding BienSo}" Width="150" FontWeight="Bold"/>
                    <DataGridTextColumn Header="ENTRY TIME" Binding="{Binding ThoiGianVao, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="160"/>
                    <DataGridTextColumn Header="EXIT TIME" Binding="{Binding ThoiGianRa, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="160"/>
                    
                    <DataGridTemplateColumn Header="REVENUE" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Tien, StringFormat=N0}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTextColumn Header="RFID CARD" Binding="{Binding CardId}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- PAGING -->
        <Border Grid.Row="3" Style="{StaticResource EnterpriseCardBorder}" Margin="0,15,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Rows per page:" Style="{StaticResource SubTitleStyle}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox Width="80" Style="{StaticResource ModernComboBox}" SelectedItem="{Binding PageSize, Mode=TwoWay}" Margin="0,0,20,0">
                    <sys:Int32>25</sys:Int32>
                    <sys:Int32>50</sys:Int32>
                    <sys:Int32>100</sys:Int32>
                    <sys:Int32>500</sys:Int32>
                </ComboBox>

                <Button Content="⏮" Width="40" Command="{Binding TrangDauCommand}" Style="{StaticResource ModernOutlineButton}" Margin="0,0,5,0" Padding="5"/>
                <Button Content="◀" Width="40" Command="{Binding TrangTruocCommand}" Style="{StaticResource ModernOutlineButton}" Margin="0,0,15,0" Padding="5"/>

                <TextBlock Text="{Binding TrangHienTai}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="/" Style="{StaticResource BaseTextBlockStyle}" Margin="5,0" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Text="{Binding TongTrang}" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>

                <Button Content="▶" Width="40" Command="{Binding TrangSauCommand}" Style="{StaticResource ModernOutlineButton}" Margin="0,0,5,0" Padding="5"/>
                <Button Content="⏭" Width="40" Command="{Binding TrangCuoiCommand}" Style="{StaticResource ModernOutlineButton}" Padding="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
