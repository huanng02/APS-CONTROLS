<Window x:Class="QuanLyGiuXe.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch sử xe"
        Height="450"
        Width="800">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- tìm kiếm -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="Tìm biển số:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <TextBox Width="200"
            Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"/>

        </StackPanel>

        <!-- bảng -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding DanhSachLichSu}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Biển số"
                                    Binding="{Binding BienSo}"/>

                <DataGridTextColumn Header="Thời gian vào"
                                    Binding="{Binding ThoiGianVao}"/>

                <DataGridTextColumn Header="Thời gian ra"
                                    Binding="{Binding ThoiGianRa}"/>

                <DataGridTextColumn Header="Tiền"
                                    Binding="{Binding Tien}"/>

                <DataGridTemplateColumn Header="Ảnh xe">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding AnhXe}" Height="60"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>