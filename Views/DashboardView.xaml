<UserControl x:Class="QuanLyGiuXe.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BgLightBrush}" FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Grid Grid.Row="0" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource APSBlueBrush}" CornerRadius="4" Padding="10" Margin="0,0,15,0">
                    <TextBlock Text="📊" FontSize="20" Foreground="White" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="SYSTEM DASHBOARD" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" VerticalAlignment="Center"/>
                <Border Background="{StaticResource BgLightBrush}" BorderBrush="{StaticResource APSBlueBrush}" BorderThickness="1" CornerRadius="15" Padding="12,5" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedDateRangeDisplay}" Foreground="{StaticResource APSBlueBrush}" FontWeight="SemiBold" FontSize="12"/>
                </Border>
                <ProgressBar IsIndeterminate="True" Width="80" Height="2" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource APSBlueBrush}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsCustomDateVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,20,0">
                    <TextBlock Text="From:" Style="{StaticResource SubTitleStyle}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="120" />
                    <TextBlock Text="To:" Style="{StaticResource SubTitleStyle}" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="120" />
                </StackPanel>

                <TextBlock Text="Range:" Style="{StaticResource SubTitleStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="130" Style="{StaticResource ModernComboBox}"
                          ItemsSource="{Binding FilterOptions}" SelectedItem="{Binding SelectedFilter}"/>

                <Button Command="{Binding ExportCommand}" Margin="10,0,0,0" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" Margin="0,0,5,0"/>
                        <TextBlock x:Name="btnText" Text="Export Excel"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- KPI Cards Row -->
        <UniformGrid Grid.Row="1" Columns="4">
            
            <!-- Card 1 -->
            <Border Style="{StaticResource EnterpriseCardBorder}" BorderBrush="{StaticResource APSBlueBrush}" BorderThickness="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="VEHICLES IN YARD" Style="{StaticResource SubTitleStyle}"/>
                        <TextBlock Text="{Binding XeTrongBai}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="🚗" FontSize="32" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Card 2 -->
            <Border Style="{StaticResource EnterpriseCardBorder}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="TRAFFIC FLOW" Style="{StaticResource SubTitleStyle}"/>
                        <TextBlock Text="{Binding LuotXeVao}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="📈" FontSize="32" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Card 3 -->
            <Border Style="{StaticResource EnterpriseCardBorder}" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="TOTAL REVENUE" Style="{StaticResource SubTitleStyle}"/>
                        <TextBlock Text="{Binding DoanhThu, StringFormat={}{0:N0} đ}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="💰" FontSize="32" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Card 4 -->
            <Border Style="{StaticResource EnterpriseCardBorder}" BorderBrush="{StaticResource APSBlueBrush}" BorderThickness="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="ACTIVE TICKETS" Style="{StaticResource SubTitleStyle}"/>
                        <TextBlock Text="{Binding VeActive}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="💳" FontSize="32" Opacity="0.3" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Charts Row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Revenue Chart -->
            <Border Grid.Column="0" Style="{StaticResource EnterpriseCardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="REVENUE OVERVIEW" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}" Margin="0,10,0,0">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding RevenueLabels}" />
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis LabelFormatter="{Binding RevenueFormatter}" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <!-- Hourly Chart -->
            <Border Grid.Column="1" Style="{StaticResource EnterpriseCardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="HOURLY TRAFFIC" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding HourlySeries}" Margin="0,10,0,0">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding HourlyLabels}" />
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis LabelFormatter="{Binding HourlyFormatter}" MinValue="0"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Row -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.6*"/>
            </Grid.ColumnDefinitions>

            <!-- Park Status -->
            <Border Grid.Column="0" Style="{StaticResource EnterpriseCardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="YARD STATUS" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Capacity: " Style="{StaticResource SubTitleStyle}"/>
                        <TextBlock Text="{Binding TongCho}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold"/>
                    </StackPanel>

                    <ProgressBar Grid.Row="2" Height="20" Value="{Binding TyLeLapDay, Mode=OneWay}" Maximum="100" 
                                 Foreground="{StaticResource APSBlueBrush}" Background="{StaticResource BgLightBrush}" BorderThickness="0" Margin="0,10"/>
                    
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Occupied" Style="{StaticResource SubTitleStyle}"/>
                            <TextBlock Text="{Binding XeTrongBai}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}"/>
                            <TextBlock Text="{Binding TyLeLapDay, StringFormat={}{0:N1}%}" Style="{StaticResource SubTitleStyle}" Foreground="{StaticResource APSBlueBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Available" Style="{StaticResource SubTitleStyle}"/>
                            <TextBlock Text="{Binding ChoTrong}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Warning if Near Full -->
                    <Border Grid.Row="3" VerticalAlignment="Bottom" Background="#FFF1F0" BorderBrush="{StaticResource APSRedBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNearFull}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" Margin="0,0,10,0"/>
                            <TextBlock Text="Yard is near capacity!" Foreground="{StaticResource APSRedBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Recent Activity -->
            <Border Grid.Column="1" Style="{StaticResource EnterpriseCardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="RECENT ACTIVITY" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentActivities}" Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PLATE NO" Binding="{Binding BienSo}" Width="150" FontWeight="Bold"/>
                            <DataGridTextColumn Header="TIME" Binding="{Binding ThoiGian, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="150"/>
                            
                            <DataGridTemplateColumn Header="ACTION" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,2" CornerRadius="12" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HanhDong}" Value="VÀO">
                                                            <Setter Property="Background" Value="#E6FFFA"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HanhDong}" Value="RA">
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding HanhDong}" FontWeight="Bold" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HanhDong}" Value="VÀO">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HanhDong}" Value="RA">
                                                                <Setter Property="Foreground" Value="{StaticResource APSRedBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="TYPE" Binding="{Binding TheLoai}" Width="120"/>
                            <DataGridTextColumn Header="FEE" Binding="{Binding GiaTien, StringFormat={}{0:N0} đ}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

