<Window x:Class="QuanLyGiuXe.C3200SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cấu hình &amp; Điều khiển C3-200" SizeToContent="Width" Height="850" Width="900" MinWidth="800" WindowStartupLocation="CenterOwner"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        Background="#F4F6F8">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                
                <!-- SECTION 1: HARDWARE CONNECTION -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🔌 KẾT NỐI PHẦN CỨNG" Style="{StaticResource Heading2Style}" Foreground="#143A7D" Margin="0,0,0,15"/>
                        <UniformGrid Columns="4" Rows="2">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="IP Address" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="IpBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="TCP Port" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="PortBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="Password" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="PwdBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10" VerticalAlignment="Bottom">
                                <Button Content="Test Connection" Style="{StaticResource ModernOutlineButton}" Height="35" Click="TestConnection_Click"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="Timeout (ms)" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="TimeoutBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="Barrier Pulse (s)" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="BarrierBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="Cooldown (ms)" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="CooldownBox" Style="{StaticResource ModernTextBox}" Height="35"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10" VerticalAlignment="Bottom">
                                <Button Content="Detailed Log" Style="{StaticResource ModernOutlineButton}" Height="35" Click="TestConnectionDetailed_Click"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- SECTION 2: RUNTIME CONTROL (Dashboard) -->
                <local:LaneRuntimeControlView Margin="0,0,0,15"/>

                <!-- SECTION 3: READER ASSIGNMENT (Per Lane) -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📡 CẤU HÌNH ĐẦU ĐỌC (READER ASSIGNMENT)" Style="{StaticResource Heading2Style}" Foreground="#143A7D" Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                                                 <!-- Lane 1 Readers (Gate 1) -->
                            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="CỔNG 1 (READER 1 &amp; 2)" FontWeight="Bold" FontSize="14" Foreground="#143A7D" Margin="0,0,0,10"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gán vào Làn:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="Door1LaneCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" SelectionChanged="Door1LaneCombo_SelectionChanged">
                                            <ComboBoxItem Tag="1">Làn 1</ComboBoxItem>
                                            <ComboBoxItem Tag="2">Làn 2</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                    
                                    <Separator Margin="0,0,0,15" Background="#F0F0F0"/>

                                    <!-- R1 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Reader 1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="R1DirCombo" Grid.Column="1" Margin="0,0,5,0" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Tag="IN">Chiều VÀO</ComboBoxItem>
                                            <ComboBoxItem Tag="OUT">Chiều RA</ComboBoxItem>
                                        </ComboBox>
                                        <CheckBox x:Name="R1EnableCheck" Grid.Column="2" Content="Bật" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
 
                                    <!-- R2 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Reader 2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="R2DirCombo" Grid.Column="1" Margin="0,0,5,0" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Tag="IN">Chiều VÀO</ComboBoxItem>
                                            <ComboBoxItem Tag="OUT">Chiều RA</ComboBoxItem>
                                        </ComboBox>
                                        <CheckBox x:Name="R2EnableCheck" Grid.Column="2" Content="Bật" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
 
                            <!-- Lane 2 Readers (Gate 2) -->
                            <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="CỔNG 2 (READER 3 &amp; 4)" FontWeight="Bold" FontSize="14" Foreground="#143A7D" Margin="0,0,0,10"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gán vào Làn:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="Door2LaneCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" SelectionChanged="Door2LaneCombo_SelectionChanged">
                                            <ComboBoxItem Tag="1">Làn 1</ComboBoxItem>
                                            <ComboBoxItem Tag="2">Làn 2</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                    
                                    <Separator Margin="0,0,0,15" Background="#F0F0F0"/>

                                    <!-- R3 -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Reader 3" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="R3DirCombo" Grid.Column="1" Margin="0,0,5,0" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Tag="IN">Chiều VÀO</ComboBoxItem>
                                            <ComboBoxItem Tag="OUT">Chiều RA</ComboBoxItem>
                                        </ComboBox>
                                        <CheckBox x:Name="R3EnableCheck" Grid.Column="2" Content="Bật" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
 
                                    <!-- R4 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Reader 4" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#666"/>
                                        <ComboBox x:Name="R4DirCombo" Grid.Column="1" Margin="0,0,5,0" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Tag="IN">Chiều VÀO</ComboBoxItem>
                                            <ComboBoxItem Tag="OUT">Chiều RA</ComboBoxItem>
                                        </ComboBox>
                                        <CheckBox x:Name="R4EnableCheck" Grid.Column="2" Content="Bật" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION 4: ADVANCED RELAY CONFIG -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚙️ NÚT BẤM (HARDWARE BUTTONS)" Style="{StaticResource Heading2Style}" Foreground="#143A7D" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Button 1 Action (AUX IN 1)" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="Button1ActionCombo" Style="{StaticResource ModernComboBox}" Height="35">
                                    <ComboBoxItem Tag="Disabled">Vô hiệu hóa (Disabled)</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenThisDoor">Mở Relay Làn hiện tại</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenGroupIn">Mở toàn bộ Làn VÀO</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenGroupOut">Mở toàn bộ Làn RA</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Button 2 Action (AUX IN 2)" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="Button2ActionCombo" Style="{StaticResource ModernComboBox}" Height="35">
                                    <ComboBoxItem Tag="Disabled">Vô hiệu hóa (Disabled)</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenThisDoor">Mở Relay Làn hiện tại</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenGroupIn">Mở toàn bộ Làn VÀO</ComboBoxItem>
                                    <ComboBoxItem Tag="OpenGroupOut">Mở toàn bộ Làn RA</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER: SAVE BUTTONS -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,10" Margin="-15,0,-15,-15">
            <UniformGrid Columns="3" HorizontalAlignment="Right" Width="450">
                <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="Reset_Click" Content="Reset Mặc Định"/>
                <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="Close_Click" Content="Đóng"/>
                <Button Style="{StaticResource ModernButton}" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="5" Click="Save_Click" Content="💾 LƯU CẤU HÌNH"/>
            </UniformGrid>
        </Border>
    </Grid>
</Window>
