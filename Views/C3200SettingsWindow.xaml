<Window x:Class="QuanLyGiuXe.C3200SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C3-200 Settings" SizeToContent="WidthAndHeight" Width="480" MinWidth="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- IP -->
                <RowDefinition Height="Auto"/> <!-- Port -->
                <RowDefinition Height="Auto"/> <!-- Password -->
                <RowDefinition Height="Auto"/> <!-- Timeout -->
                <RowDefinition Height="Auto"/> <!-- Barrier -->
                <RowDefinition Height="Auto"/> <!-- Cooldown -->
                <RowDefinition Height="12"/>   <!-- spacer -->
                <RowDefinition Height="Auto"/> <!-- Gate In Group -->
                <RowDefinition Height="Auto"/> <!-- Gate Out Group -->
                <RowDefinition Height="Auto"/> <!-- Mode label + radios -->
                <RowDefinition Height="12"/>   <!-- spacer -->
                <RowDefinition Height="Auto"/> <!-- Button1 action -->
                <RowDefinition Height="Auto"/> <!-- Button2 action -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">IP Address:</TextBlock>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="IpBox" Margin="6,4" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">TCP Port:</TextBlock>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortBox" Margin="6,4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Password:</TextBlock>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="PwdBox" Margin="6,4" />

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Timeout (ms):</TextBlock>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TimeoutBox" Margin="6,4" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Barrier Duration (s):</TextBlock>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="BarrierBox" Margin="6,4" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Card Cooldown (ms):</TextBlock>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="CooldownBox" Margin="6,4" />

            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Gate In Group:</TextBlock>
            <ComboBox Grid.Row="7" Grid.Column="1" x:Name="GateInCombo" Margin="6,4" Width="220" />

            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Gate Out Group:</TextBlock>
            <ComboBox Grid.Row="8" Grid.Column="1" x:Name="GateOutCombo" Margin="6,4" Width="220" />

            <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Mode:</TextBlock>
            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="6,6,0,0">
                <RadioButton x:Name="AutomaticRadio" GroupName="ForceMode" Content="Automatic (map by Gate In/Out)" Margin="0,0,12,0" Checked="ForceMode_Checked"/>
                <RadioButton x:Name="ForceAllInRadio" GroupName="ForceMode" Content="Force all scans as IN" Margin="0,0,12,0" Checked="ForceMode_Checked"/>
                <RadioButton x:Name="ForceAllOutRadio" GroupName="ForceMode" Content="Force all scans as OUT" Checked="ForceMode_Checked"/>
            </StackPanel>

            <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Button1 Action:</TextBlock>
            <ComboBox Grid.Row="11" Grid.Column="1" x:Name="Button1ActionCombo" Margin="6,4" Width="220">
                <ComboBoxItem Tag="Disabled">Disabled</ComboBoxItem>
                <ComboBoxItem Tag="OpenThisDoor">Open this physical door</ComboBoxItem>
                <ComboBoxItem Tag="OpenGroupIn">Open IN group</ComboBoxItem>
                <ComboBoxItem Tag="OpenGroupOut">Open OUT group</ComboBoxItem>
            </ComboBox>

            <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,6" VerticalAlignment="Center">Button2 Action:</TextBlock>
            <ComboBox Grid.Row="12" Grid.Column="1" x:Name="Button2ActionCombo" Margin="6,4" Width="220">
                <ComboBoxItem Tag="Disabled">Disabled</ComboBoxItem>
                <ComboBoxItem Tag="OpenThisDoor">Open this physical door</ComboBoxItem>
                <ComboBoxItem Tag="OpenGroupIn">Open IN group</ComboBoxItem>
                <ComboBoxItem Tag="OpenGroupOut">Open OUT group</ComboBoxItem>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Margin="6,0" Click="TestConnection_Click">Test</Button>
            <Button Width="100" Margin="6,0" Click="Reset_Click">Reset</Button>
            <Button Width="100" Margin="6,0" Click="Save_Click">Save</Button>
            <Button Width="100" Margin="6,0" Click="Close_Click">Close</Button>
        </StackPanel>
    </Grid>
</Window>
    