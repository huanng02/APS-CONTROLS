<Window x:Class="QuanLyGiuXe.C3200SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controller Configuration" SizeToContent="WidthAndHeight" Width="650" MinWidth="500" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgLightBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource EnterpriseCardBorder}" Padding="25">
            <StackPanel>
                <TextBlock Text="C3-200 CONTROLLER SETTINGS" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,20"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- IP -->
                        <RowDefinition Height="Auto"/> <!-- Port -->
                        <RowDefinition Height="Auto"/> <!-- Password -->
                        <RowDefinition Height="Auto"/> <!-- Timeout -->
                        <RowDefinition Height="Auto"/> <!-- Barrier -->
                        <RowDefinition Height="Auto"/> <!-- Cooldown -->
                        <RowDefinition Height="15"/>   <!-- spacer -->
                        <RowDefinition Height="Auto"/> <!-- Gate In Group -->
                        <RowDefinition Height="Auto"/> <!-- Gate Out Group -->
                        <RowDefinition Height="Auto"/> <!-- Mode label + radios -->
                        <RowDefinition Height="15"/>   <!-- spacer -->
                        <RowDefinition Height="Auto"/> <!-- Button1 action -->
                        <RowDefinition Height="Auto"/> <!-- Button2 action -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="IP ADDRESS" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="IpBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="TCP PORT" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="COMM PASSWORD" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="PwdBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="TIMEOUT (MS)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TimeoutBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="BARRIER PULSE (S)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="BarrierBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="CARD COOLDOWN (MS)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="CooldownBox" Style="{StaticResource ModernTextBox}" Margin="10,5"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="GATE GROUP A (Door 1)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <ComboBox Grid.Row="7" Grid.Column="1" x:Name="GateInCombo" Style="{StaticResource ModernComboBox}" Margin="10,5">
                        <ComboBoxItem Tag="1">Lane 1</ComboBoxItem>
                        <ComboBoxItem Tag="2">Lane 2</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="GATE GROUP B (Door 2)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <ComboBox Grid.Row="8" Grid.Column="1" x:Name="GateOutCombo" Style="{StaticResource ModernComboBox}" Margin="10,5">
                        <ComboBoxItem Tag="1">Lane 1</ComboBoxItem>
                        <ComboBoxItem Tag="2">Lane 2</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="OPERATIONAL MODE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Vertical" Margin="10,8,0,0">
                        <RadioButton x:Name="AutomaticRadio" GroupName="ForceMode" Content="Automatic (Lane 1 &amp; Lane 2)" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8" Checked="ForceMode_Checked"/>
                        <RadioButton x:Name="ForceAllInRadio" GroupName="ForceMode" Content="Force All Lane 1" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8" Checked="ForceMode_Checked"/>
                        <RadioButton x:Name="ForceAllOutRadio" GroupName="ForceMode" Content="Force All Lane 2" Style="{StaticResource ModernRadioButton}" Checked="ForceMode_Checked"/>
                    </StackPanel>

                    <TextBlock Grid.Row="11" Grid.Column="0" Text="BUTTON 1 ACTION" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <ComboBox Grid.Row="11" Grid.Column="1" x:Name="Button1ActionCombo" Style="{StaticResource ModernComboBox}" Margin="10,5">
                        <ComboBoxItem Tag="Disabled">Disabled</ComboBoxItem>
                        <ComboBoxItem Tag="OpenThisDoor">Open Local Relay</ComboBoxItem>
                        <ComboBoxItem Tag="OpenGroupIn">Trigger IN Group</ComboBoxItem>
                        <ComboBoxItem Tag="OpenGroupOut">Trigger OUT Group</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="BUTTON 2 ACTION" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" Margin="0,8"/>
                    <ComboBox Grid.Row="12" Grid.Column="1" x:Name="Button2ActionCombo" Style="{StaticResource ModernComboBox}" Margin="10,5">
                        <ComboBoxItem Tag="Disabled">Disabled</ComboBoxItem>
                        <ComboBoxItem Tag="OpenThisDoor">Open Local Relay</ComboBoxItem>
                        <ComboBoxItem Tag="OpenGroupIn">Trigger IN Group</ComboBoxItem>
                        <ComboBoxItem Tag="OpenGroupOut">Trigger OUT Group</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,20,0,0">
            <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="TestConnection_Click">Test Connection</Button>
            <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="TestConnectionDetailed_Click">Detailed Log</Button>
            <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="Reset_Click">Reset Defaults</Button>
            <Button Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Margin="5" Click="Save_Click">SAVE CONFIG</Button>
            <Button Style="{StaticResource ModernOutlineButton}" Margin="5" Click="Close_Click">CLOSE</Button>
        </UniformGrid>
    </Grid>
</Window>
    
