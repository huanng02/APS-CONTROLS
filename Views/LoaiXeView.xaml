<UserControl x:Class="QuanLyGiuXe.Views.LoaiXeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLyGiuXe.ViewModels"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:LoaiXeViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header & Action Bar -->
        <Border Grid.Row="0" Style="{StaticResource EnterpriseCardBorder}" Margin="0,0,0,15" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource APSBlueBrush}" CornerRadius="4" Padding="10" Margin="0,0,15,0">
                        <TextBlock Text="🚗" FontSize="20" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="VEHICLE TYPES" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}"/>
                        <TextBlock Text="Configure vehicle categories and permissions" Style="{StaticResource SubTitleStyle}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource ModernOutlineButton}" Margin="0,0,10,0"/>
                    <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                    <Button Content="Add Vehicle Type" Command="{Binding AddCommand}" Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cards Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DanhSach}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="280" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,15,15" Padding="20">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EnterpriseCardBorder}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource APSBlueBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource APSBlueBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    
                                    <Border HorizontalAlignment="Right" CornerRadius="12" Padding="10,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Inactive">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding TrangThai}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="Inactive">
                                                            <Setter Property="Foreground" Value="{StaticResource APSRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,20">
                                    <TextBlock Text="🚗" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TenLoai}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Id, StringFormat='TYPE ID: {0}'}" Style="{StaticResource SubTitleStyle}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Content="Edit" 
                                            Command="{Binding DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{StaticResource ModernOutlineButton}" 
                                            Margin="0,0,5,0"/>
                                            
                                    <Button Grid.Column="1" Content="Delete" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{StaticResource DangerButton}" 
                                            Margin="5,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

