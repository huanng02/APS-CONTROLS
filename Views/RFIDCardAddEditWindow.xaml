<Window x:Class="QuanLyGiuXe.Views.RFIDCardAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:QuanLyGiuXe.Converters"
        Title="RFID CARD REGISTRATION" Width="650" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgLightBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">
                <!-- Card / RFID section -->
                <Border Style="{StaticResource EnterpriseCardBorder}" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="IDENTITY INFORMATION" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CARD UID" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtCardUID" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                     Text="{Binding CardUID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="True"
                                     Loaded="TxtCardUID_Loaded"
                                     PreviewKeyDown="TxtCardUID_PreviewKeyDown"
                                     PreviewTextInput="TxtCardUID_PreviewTextInput"
                                     ContextMenuOpening="TxtCardUID_ContextMenuOpening" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DISPLAY NAME" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding CardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Vehicle and Ticket Config -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource EnterpriseCardBorder}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="VEHICLE TYPE" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,10" />
                            <ComboBox Style="{StaticResource ModernComboBox}" ItemsSource="{Binding LoaiXeList}" DisplayMemberPath="TenLoai" SelectedValuePath="Id" SelectedValue="{Binding LoaiXeId, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource EnterpriseCardBorder}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="TICKET CATEGORY" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,10" />
                            <ComboBox Style="{StaticResource ModernComboBox}" ItemsSource="{Binding LoaiVeFiltered}" DisplayMemberPath="TenLoai" SelectedValuePath="Id" SelectedValue="{Binding LoaiVeId, Mode=TwoWay}" IsEnabled="{Binding CanChangeLoaiVe}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Monthly Details -->
                <Border Style="{StaticResource EnterpriseCardBorder}" Padding="20" Visibility="{Binding IsMonthlyTicket, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="MEMBERSHIP DETAILS" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PLATE NUMBER" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding BienSo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ISSUE DATE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                            <DatePicker Grid.Column="1" SelectedDate="{Binding NgayDangKy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EXPIRY DATE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                            <DatePicker Grid.Column="1" SelectedDate="{Binding NgayHetHan}" IsEnabled="False" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="CANCEL" Style="{StaticResource ModernOutlineButton}" Width="120" Height="40" Margin="0,0,10,0" Command="{Binding CancelCommand}" />
            <Button Content="CONFIRM &amp; SAVE" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="180" Height="40" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>

