<Window x:Class="QuanLyGiuXe.Views.RFIDCardAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:QuanLyGiuXe.Converters"
        Title="ĐĂNG KÝ THẺ RFID" 
        SizeToContent="Height" 
        Width="650" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource APSBlueBrush}" CornerRadius="12,12,0,0" Padding="25,20">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Background="#20FFFFFF" CornerRadius="20" Margin="0,0,15,0">
                            <TextBlock Text="💳" FontSize="20" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ĐĂNG KÝ THẺ RFID" FontWeight="Bold" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Cấp phát và quản lý thông tin thẻ gửi xe" Foreground="#B0C4DE" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource ModernOutlineButton}" BorderThickness="0" Foreground="White"
                            Width="30" Height="30" Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" MaxHeight="600" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical" Margin="25">
                    <!-- Card / RFID section -->
                    <Border Style="{StaticResource EnterpriseCardBorder}" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="THÔNG TIN ĐỊNH DANH" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MÃ THẺ (UID)" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtCardUID" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                         Text="{Binding CardUID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True"
                                         Loaded="TxtCardUID_Loaded"
                                         PreviewKeyDown="TxtCardUID_PreviewKeyDown"
                                         PreviewTextInput="TxtCardUID_PreviewTextInput"
                                         ContextMenuOpening="TxtCardUID_ContextMenuOpening" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TÊN HIỂN THỊ" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding CardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Vehicle and Ticket Config -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource EnterpriseCardBorder}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="LOẠI XE" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,10" />
                                <ComboBox Style="{StaticResource ModernComboBox}" ItemsSource="{Binding LoaiXeList}" DisplayMemberPath="TenLoai" SelectedValuePath="Id" SelectedValue="{Binding LoaiXeId, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource EnterpriseCardBorder}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="LOẠI VÉ" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,10" />
                                <ComboBox Style="{StaticResource ModernComboBox}" ItemsSource="{Binding LoaiVeFiltered}" DisplayMemberPath="TenLoai" SelectedValuePath="Id" SelectedValue="{Binding LoaiVeId, Mode=TwoWay}" IsEnabled="{Binding CanChangeLoaiVe}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Monthly Details -->
                    <Border Style="{StaticResource EnterpriseCardBorder}" Padding="20" Visibility="{Binding IsMonthlyTicket, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="THÔNG TIN THẺ THÁNG" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="BIỂN SỐ XE" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="{Binding BienSo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="NGÀY ĐĂNG KÝ" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                                <DatePicker Grid.Column="1" SelectedDate="{Binding NgayDangKy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="NGÀY HẾT HẠN" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center" />
                                <DatePicker Grid.Column="1" SelectedDate="{Binding NgayHetHan}" IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgLightBrush}" CornerRadius="0,0,12,12" Padding="25,20" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="HỦY BỎ" Style="{StaticResource ModernOutlineButton}" Width="120" Height="40" Margin="0,0,12,0" Command="{Binding CancelCommand}" />
                    <Button Content="XÁC NHẬN &amp; LƯU" Style="{StaticResource ModernButton}" Background="{StaticResource SuccessBrush}" Width="180" Height="40" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
