<Window x:Class="QuanLyGiuXe.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu"
        Height="500"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA">

	<Grid>

		<Border Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="20">

			<StackPanel>

				<!-- Header -->
				<TextBlock Text="Đổi mật khẩu"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,25"/>

				<!-- Old Password -->
				<TextBlock Text="Mật khẩu cũ"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

				<PasswordBox x:Name="OldPasswordBox"
                             Height="38"
                             Margin="0,0,0,15"
                             Padding="10"
                             PasswordChanged="OldPasswordBox_PasswordChanged"/>

				<!-- New Password -->
				<TextBlock Text="Mật khẩu mới"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

				<PasswordBox x:Name="NewPasswordBox"
                             Height="38"
                             Margin="0,0,0,15"
                             Padding="10"
                             PasswordChanged="NewPasswordBox_PasswordChanged"/>

				<!-- Confirm Password -->
				<TextBlock Text="Xác nhận mật khẩu"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

				<PasswordBox x:Name="ConfirmPasswordBox"
                             Height="38"
                             Margin="0,0,0,25"
                             Padding="10"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

				<!-- Buttons -->
				<Grid>

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<!-- Change Password -->
					<Button Grid.Column="0"
                            Height="42"
                            Content="🔒 Đổi mật khẩu"
                            Background="#F39C12"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

					<!-- Close -->
					<Button Grid.Column="2"
                            Height="42"
                            Content="❌ Đóng"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click"/>
				</Grid>

			</StackPanel>

		</Border>

	</Grid>
</Window>