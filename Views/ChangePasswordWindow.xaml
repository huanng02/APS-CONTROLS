<Window x:Class="QuanLyGiuXe.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CHANGE PASSWORD"
        SizeToContent="Height"
        MinHeight="550"
        Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgLightBrush}">

    <Grid Margin="30">
        <Border Style="{StaticResource EnterpriseCardBorder}" Padding="35">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="SECURITY UPDATE" Style="{StaticResource Heading1Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <!-- Old Password -->
                <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,8"/>
                <PasswordBox x:Name="OldPasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,15" PasswordChanged="OldPasswordBox_PasswordChanged"/>

                <!-- New Password -->
                <TextBlock Text="NEW PASSWORD" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,8"/>
                <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,15" PasswordChanged="NewPasswordBox_PasswordChanged"/>

                <!-- Confirm Password -->
                <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,8"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,30" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="UPDATE PASSWORD" Style="{StaticResource ModernButton}" Background="{StaticResource APSBlueBrush}" Height="45" 
                            Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Grid.Column="2" Content="CLOSE" Style="{StaticResource ModernOutlineButton}" Height="45" Click="Close_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
