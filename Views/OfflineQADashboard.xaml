<Window x:Class="QuanLyGiuXe.Views.OfflineQADashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        xmlns:converters="clr-namespace:QuanLyGiuXe.Converters"
        mc:Ignorable="d"
        Title="🚀 OFFLINE &amp; MULTI-ZONE RESILIENCY ENGINE QA DASHBOARD" Height="820" Width="1280"
        Background="#12121E" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        
        <!-- Premium dark scrollbar and visual overrides -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0,0,0,3" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" RecognizesAccessKey="True" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#222235"/>
                                <Setter Property="Foreground" Value="#3498DB"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#8F94FB"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1D1D30" CornerRadius="10" Padding="20,15" Margin="0,0,0,15" BorderBrush="#2F2F4A" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="OFFLINE-FIRST RESILIENCY &amp; MULTI-ZONE TOPO COCKPIT" Foreground="White" FontSize="22" FontWeight="ExtraBold"/>
                    <TextBlock Text="Phase 8.1 - Enterprise Relational Multi-Zone Architecture, Failover Validation, &amp; Integrity Assurances" Foreground="#8F94FB" FontSize="12" FontWeight="SemiBold" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#26FFFFFF" CornerRadius="15" Padding="12,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding Conn.IsOnline, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='TRUE:#2ECC71|FALSE:#E74C3C'}"/>
                            <TextBlock Text="{Binding Conn.StatusText}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT CONTROL PANEL (RESILIENCY AND LOGS) -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- System State controls -->
                <Border Grid.Row="0" Background="#1D1D30" CornerRadius="10" Padding="15" BorderBrush="#2F2F4A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FAILOVER &amp; EMERGENCIES" Foreground="#FF5722" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>

                        <Button Command="{Binding ForceOfflineCommand}" Content="⚡ FORCE DISCONNECT (OFFLINE)" Background="#E74C3C" Margin="0,0,0,8" Height="36"/>
                        <Button Command="{Binding ForceOnlineCommand}" Content="🔌 RESTORE CONNECTION (ONLINE)" Background="#2ECC71" Margin="0,0,0,12" Height="36"/>

                        <TextBlock Text="RECOVERY CONTROLS" Foreground="#3498DB" FontWeight="Bold" FontSize="13" Margin="0,5,0,8"/>
                        <Button Command="{Binding ForceAutoRepairCommand}" Content="🔧 TRIGGER SESSION AUTO-REPAIR" Background="#8E44AD" Margin="0,0,0,8" Height="36"/>
                        <Button Command="{Binding TestWriteQueueCommand}" Content="📝 WRITE TEST TRANSACTION" Background="#D35400" Margin="0,0,0,8" Height="36"/>
                        <Button Command="{Binding StressTestCommand}" Content="💥 MASSIVE QUEUE STRESS TEST" Background="#7F8C8D" Margin="0,0,0,0" Height="36"/>
                    </StackPanel>
                </Border>

                <!-- Live Test Logging panel -->
                <Border Grid.Row="1" Background="#1D1D30" CornerRadius="10" Padding="15" Margin="0,15,0,0" BorderBrush="#2F2F4A" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="INTEGRATION TEST TRACE" Foreground="#2ECC71" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="1" Text="{Binding TestLog}" Background="#0B0B14" Foreground="#2ECC71" 
                                 BorderThickness="1" BorderBrush="#1F1F35" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT TABBED WORKSPACE -->
            <TabControl Grid.Column="1" Background="#1D1D30" BorderThickness="1" BorderBrush="#2F2F4A">
                
                <!-- TAB 1: TELEMETRY & OFFLINE ENGINE -->
                <TabItem Header="🛰️  RESILIENCY TELEMETRY">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Telemetry Cards -->
                        <UniformGrid Rows="1" Columns="4" Grid.Row="0" Margin="0,0,0,15">
                            <Border Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#2ECC71" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="LIVE VEHICLES" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TelemetryLiveVehicleCount}" Foreground="#2ECC71" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#3498DB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE SESSIONS" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TelemetryActiveSessions}" Foreground="#3498DB" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E74C3C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CORRUPTED SESSIONS" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TelemetrySuspiciousSessions}" Foreground="#E74C3C" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,0,0" BorderBrush="#F1C40F" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="LOCAL QUEUE SIZE" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TelemetryPendingOfflineSync}" Foreground="#F1C40F" FontSize="26" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Offline Queue Grid -->
                        <Border Grid.Row="1" Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="LOCAL OFFLINE TRANSACTION QUEUE (SQLite)" Foreground="#8F94FB" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Transactions.Count, StringFormat='({0} items)'}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time (UTC)" Binding="{Binding CreatedUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="150"/>
                                        <DataGridTemplateColumn Header="Status" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding StatusColor}" CornerRadius="3" Padding="6,2">
                                                        <TextBlock Text="{Binding SyncStatus}" Foreground="White" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="70"/>
                                        <DataGridTextColumn Header="Errors / Reason" Binding="{Binding ErrorMessage}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Session Consistency Audit logs -->
                        <Border Grid.Row="2" Background="#161626" CornerRadius="8" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="LIVE SESSION CONSISTENCY AUDIT LOGS" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding AuditLogs}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time (UTC)" Binding="{Binding CreatedUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                                        <DataGridTextColumn Header="Session ID / Card" Binding="{Binding SessionId}" Width="150"/>
                                        <DataGridTextColumn Header="Event Code" Binding="{Binding EventType}" Width="120"/>
                                        <DataGridTextColumn Header="Old" Binding="{Binding OldState}" Width="80"/>
                                        <DataGridTextColumn Header="New" Binding="{Binding NewState}" Width="80"/>
                                        <DataGridTextColumn Header="Resolution / Audit Details" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: PARKING TOPOLOGY CONFIG -->
                <TabItem Header="📐  PARKING TOPOLOGY CONFIG">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Top-Left: Sites Panel -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,10,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="1. PARKING SITES" Foreground="#8F94FB" FontWeight="Bold" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Sites}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="40"/>
                                        <DataGridTextColumn Header="Site Code" Binding="{Binding SiteCode}" Width="100"/>
                                        <DataGridTextColumn Header="Site Name" Binding="{Binding SiteName}" Width="130"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTemplateColumn Header="Action" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.DeleteSiteCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" Content="Del" Background="#E74C3C" Padding="6,2" FontSize="10"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewSiteCode, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="0,0,4,0" Tag="Code" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <TextBox Text="{Binding NewSiteName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="0,0,4,0" Tag="Name" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <TextBox Text="{Binding NewSiteDesc, UpdateSourceTrigger=PropertyChanged}" Grid.Column="2" Margin="0,0,4,0" Tag="Description" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <Button Command="{Binding SaveSiteCommand}" Content="Add" Grid.Column="3" Height="26" Padding="5,0" FontSize="11"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Top-Right: Zones Panel -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="2. PARKING ZONES (CAPACITIES)" Foreground="#8F94FB" FontWeight="Bold" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Zones}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Site" Binding="{Binding SiteId}" Width="40"/>
                                        <DataGridTextColumn Header="Zone Code" Binding="{Binding ZoneCode}" Width="100"/>
                                        <DataGridTextColumn Header="Zone Name" Binding="{Binding ZoneName}" Width="130"/>
                                        <DataGridTextColumn Header="Max Cap" Binding="{Binding MaxCapacity}" Width="70"/>
                                        <DataGridTemplateColumn Header="Action" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.DeleteZoneCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" Content="Del" Background="#E74C3C" Padding="6,2" FontSize="10"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding Sites}" SelectedItem="{Binding SelectedZoneSite}" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,4,4" DisplayMemberPath="SiteCode" Background="#222" BorderThickness="1" BorderBrush="#444" Height="26"/>
                                    <TextBox Text="{Binding NewZoneCode, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="2" Margin="0,0,4,4" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <TextBox Text="{Binding NewZoneName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" Margin="0,0,0,4" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    
                                    <TextBox Text="{Binding NewZoneDesc, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,4,0" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <TextBox Text="{Binding NewZoneCapacity, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="3" Margin="0,0,4,0" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <Button Command="{Binding SaveZoneCommand}" Content="Add" Grid.Row="1" Grid.Column="4" Height="26" Padding="5,0" FontSize="11"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Bottom-Left: Lanes Assignment -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#161626" CornerRadius="8" Padding="15" Margin="0,10,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="3. LANES ZONE ASSIGNMENT" Foreground="#8F94FB" FontWeight="Bold" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Lanes}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Lane Code" Binding="{Binding LaneCode}" Width="100"/>
                                        <DataGridTextColumn Header="Lane Name" Binding="{Binding LaneName}" Width="130"/>
                                        <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="80"/>
                                        <DataGridTextColumn Header="Assigned Zone" Binding="{Binding ZoneName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding Lanes}" SelectedItem="{Binding SelectedLane}" DisplayMemberPath="LaneName" Grid.Column="0" Margin="0,0,4,0" Background="#222" Height="28"/>
                                    <ComboBox ItemsSource="{Binding Zones}" SelectedItem="{Binding SelectedLaneZone}" DisplayMemberPath="ZoneName" Grid.Column="1" Margin="0,0,4,0" Background="#222" Height="28"/>
                                    <Button Command="{Binding AssignLaneCommand}" Content="Map" Grid.Column="2" Height="28" Padding="5,0"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Bottom-Right: C3 Controller configs -->
                        <Border Grid.Row="1" Grid.Column="1" Background="#161626" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="4. C3 CONTROLLERS PLACEMENT" Foreground="#8F94FB" FontWeight="Bold" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Controllers}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding ControllerName}" Width="120"/>
                                        <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="120"/>
                                        <DataGridTextColumn Header="Assigned Zone ID" Binding="{Binding ZoneId}" Width="*"/>
                                        <DataGridTemplateColumn Header="Action" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.DeleteControllerCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" Content="Del" Background="#E74C3C" Padding="6,2" FontSize="10"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewControllerName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="0,0,4,0" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <TextBox Text="{Binding NewControllerIp, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="0,0,4,0" Background="#222" Foreground="White" BorderThickness="1" BorderBrush="#444" VerticalContentAlignment="Center" Height="26"/>
                                    <ComboBox ItemsSource="{Binding Zones}" SelectedItem="{Binding SelectedControllerZone}" DisplayMemberPath="ZoneCode" Grid.Column="2" Margin="0,0,4,0" Background="#222" Height="26"/>
                                    <Button Command="{Binding SaveControllerCommand}" Content="Add" Grid.Column="3" Height="26" Padding="5,0" FontSize="11"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 3: RESILIENCY & MULTI-ZONE INTEGRATION QA -->
                <TabItem Header="🏆  MULTI-ZONE QA AUTOMATED SUITE">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Automated Test Controller Header -->
                        <Border Grid.Row="0" Background="#161626" CornerRadius="8" Padding="20" Margin="0,0,0,15" BorderBrush="#8E44AD" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="INTEGRATION RESILIENCY CERTIFICATION ENGINE" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Pressing the master button below will automatically run all 5 complex failover topologies, dynamic mapping, and SQLite offline recovery tests sequentially." Foreground="#AAA" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Command="{Binding RunAllTestsCommand}" Content="🚀 RUN FULL INTEGRATION QA SUITE" Background="#8E44AD" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="25,12" FontSize="13" FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <!-- Cards detailing the 5 Scenarios -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <UniformGrid Columns="2" Rows="3">
                                    
                                    <!-- Scenario 1 Card -->
                                    <Border Background="#161626" CornerRadius="8" Padding="15" Margin="0,0,10,10" BorderBrush="#2F2F4A" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
