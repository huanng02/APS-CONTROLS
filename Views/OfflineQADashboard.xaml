<Window x:Class="QuanLyGiuXe.Views.OfflineQADashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        xmlns:converters="clr-namespace:QuanLyGiuXe.Converters"
        mc:Ignorable="d"
        Title="🚀 OFFLINE MODE QA DASHBOARD" Height="700" Width="1000"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="OFFLINE-FIRST QA CENTER" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Step 6.2 - Production-Grade Resilience Testing" Foreground="#888" FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Control Panel -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Border Background="#2A2A3D" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="SYSTEM STATE" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <Grid Margin="0,5">
                            <TextBlock Text="Status:" Foreground="Gray"/>
                            <TextBlock Text="{Binding Conn.StatusText}" Foreground="{Binding Conn.StatusColor}" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <TextBlock Text="Simulation:" Foreground="Gray"/>
                            <TextBlock Text="{Binding Conn.IsSimulatingOffline, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='TRUE:OFFLINE|FALSE:NORMAL'}" 
                                       Foreground="{Binding Conn.IsSimulatingOffline, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='TRUE:#E74C3C|FALSE:#27AE60'}" 
                                       HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>

                        <Separator Background="#444" Margin="0,15"/>

                        <Button Command="{Binding ForceOfflineCommand}" Content="FORCE SQL OFFLINE" Background="#E74C3C" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                        <Button Command="{Binding ForceOnlineCommand}" Content="FORCE SQL ONLINE" Background="#27AE60" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                        
                        <Separator Background="#444" Margin="0,15"/>
                        
                        <Button Command="{Binding TestReadCacheCommand}" Content="TEST CACHE FALLBACK" Background="#3498DB" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                        <Button Command="{Binding TestWriteQueueCommand}" Content="TEST QUEUE WRITE" Background="#F39C12" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                        <Button Command="{Binding StressTestCommand}" Content="TEST MASSIVE QUEUE" Background="#9B59B6" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                        <Button Command="{Binding TestOfflineCardValidationCommand}" Content="TEST OFFLINE VALIDATION" Background="#E67E22" Foreground="White" Height="40" Margin="0,5" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <Border Background="#2A2A3D" CornerRadius="10" Padding="15" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="LOGS" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox Text="{Binding TestLog}" Height="200" Background="#111" Foreground="#0F0" 
                                 BorderThickness="0" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Queue View -->
            <Border Grid.Column="1" Background="#2A2A3D" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="OFFLINE QUEUE" Foreground="#CCC" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Transactions.Count, StringFormat='({0} items)'}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <Button Command="{Binding RefreshQueueCommand}" Content="REFRESH" Background="Transparent" Foreground="#3498DB" Margin="20,0,0,0" BorderThickness="0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" RowBackground="#222" Foreground="White"
                              CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding CreatedUtc, StringFormat='HH:mm:ss'}" Width="80"/>
                            <DataGridTemplateColumn Header="Type" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TransactionType}" Foreground="#3498DB"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}" CornerRadius="3" Padding="5,2">
                                            <TextBlock Text="{Binding SyncStatus}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="60"/>
                            <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Offline Mode Phase 6.2 - APS-CONTROLS" Foreground="#555" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>
