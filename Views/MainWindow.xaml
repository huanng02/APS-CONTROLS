<Window x:Class="QuanLyGiuXe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APS - Quản Lý Xe Ra/Vào"
        Height="800"
        Width="1280"
        WindowState="Maximized"
        xmlns:conv="clr-namespace:QuanLyGiuXe.Converters"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        xmlns:viewmodels="clr-namespace:QuanLyGiuXe.ViewModels"
        xmlns:comps="clr-namespace:QuanLyGiuXe.Views.Components"
        Background="{StaticResource BgLightBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ConnectionStatusToBrushConverter x:Key="LegacyStatusToBrush"/>
        <ServicesConnection:ConnectionStateToBrushConverter x:Key="StateToBrush" xmlns:ServicesConnection="clr-namespace:QuanLyGiuXe.Services.Connection"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- STATUS BAR (APS BLUE) -->
        <Border Grid.Row="0" Background="{StaticResource APSBlueBrush}" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ToggleSidebarCommand}" 
                            Foreground="White" Margin="0,0,15,0" 
                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center">
                        <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" 
                              Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" Padding="5">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="APS" Foreground="White" FontSize="18" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Width="1" Background="#66FFFFFF" Margin="0,5,15,5"/>
                    <TextBlock Text="ACCESS CONTROL SYSTEM"
                               FontSize="14" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center" Opacity="0.9"/>
                </StackPanel>

                <!-- Connection Status Indicators -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- SQL REALTIME STATUS CHIP (NEW) -->
                    <comps:ConnectivityStatusChip Margin="0,0,15,0"/>

                    <!-- C3-200 monitor indicator -->
                    <Border Background="#26FFFFFF" CornerRadius="15" Padding="12,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding C3State, Converter={StaticResource StateToBrush}}"/>
                            <TextBlock Text="{Binding C3StatusLabel}"
                                       Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Camera Làn Vào monitor indicator -->
                    <Border Background="#26FFFFFF" CornerRadius="15" Padding="12,5">
                        <StackPanel Orientation="Horizontal" ToolTip="Trạng thái Camera Làn Vào">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding CamVaoState, Converter={StaticResource StateToBrush}}"/>
                            <TextBlock Text="Cam Vào"
                                       Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1" Margin="8,6,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource APSBlueBrush}" CornerRadius="8" Width="220">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Name="CollapseSB">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="65" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard Name="ExpandSB">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="220" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Grid.Row="0">
