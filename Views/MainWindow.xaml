<Window x:Class="QuanLyGiuXe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APS - Quản Lý Xe Ra/Vào"
        Height="800"
        Width="1280"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Theme -->
        <SolidColorBrush x:Key="AccentBrush" Color="#2C3E50" />
        <SolidColorBrush x:Key="AccentLight" Color="#34495E" />
        <SolidColorBrush x:Key="PositiveBrush" Color="#27AE60" />
        <SolidColorBrush x:Key="WarningBrush" Color="#E67E22" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E74C3C" />
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedText" Color="#6B7280" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#2C3E50" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E9EEF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#E6EEF6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- STATUS BAR -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="APS - QUẢN LÝ XE RA/VÀO"
                           FontSize="16" FontWeight="Bold" Foreground="White"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0,0,0">
                    <TextBlock Text="{Binding TrangThaiKetNoi}" Foreground="#2ECC71"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Margin="8,6,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR (FULL UPDATED + CRUD) -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>

                    <TextBlock Text="DASHBOARD"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="4"
                               Foreground="{StaticResource AccentLight}" />

                    <!-- SYSTEM -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📋 Realtime Log"
                            Click="MoRealtimeLog_Click" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📋 Logs nút"
                            Click="MoButtonLogs_Click" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📜 Lịch sử xe"
                            Click="MoLichSu" />

                    <Separator Margin="6"/>

                    <!-- RFID -->
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📡 Danh sách thẻ RFID"
                            Click="MoDanhSachRFID" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="💳 Quản lý thẻ RFID"
                            Click="MoQuanLyThe" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📜 Lịch sử gia hạn"
                            Click="MoLichSuGiaHan_Click" />

                    <Separator Margin="6"/>

                    <!-- CRUD -->
                    <TextBlock Text="QUẢN LÝ DANH MỤC"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="4,10,4,4"
                               Foreground="{StaticResource AccentLight}" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
        Content="🚗 Loại xe"
        Tag="LoaiXe"
        Click="OpenModule_Click"/>

                    <Button Style="{StaticResource SidebarButtonStyle}"
        Content="🎫 Loại vé"
        Tag="LoaiVe"
        Click="OpenModule_Click"/>

                    <Button Style="{StaticResource SidebarButtonStyle}"
        Content="💳 RFID"
        Tag="RFID"
        Click="OpenModule_Click"/>

                    <Button Style="{StaticResource SidebarButtonStyle}"
        Content="💰 Bảng giá"
        Tag="BangGia"
        Click="OpenModule_Click"/>

                    <Separator Margin="6"/>

                    <!-- SYSTEM -->
                    <TextBlock Text="HỆ THỐNG"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="4,10,4,4"
                               Foreground="{StaticResource AccentLight}" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="📷 Camera"
                            Click="MoCameraSettings_Click" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="⚙ C3-200"
                            Click="MoC3200Settings_Click" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="⚙ Cấu hình nâng cao"
                            Click="MoAdvancedSettings_Click" />

                </StackPanel>
            </Border>

            <!-- ══════════ LUỒNG XE VÀO ══════════ -->
            <Border Grid.Column="2"
        Style="{StaticResource CardStyle}"
        BorderBrush="{StaticResource PositiveBrush}" BorderThickness="0,3,0,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Background="{StaticResource PositiveBrush}" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                        <TextBlock Text="🟢 LUỒNG XE VÀO  ─  Gate 1 Reader 1"
                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- 2 Cameras side by side -->
                    <Grid Grid.Row="1" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <Image x:Name="CameraVao1" Stretch="Uniform"/>
                                <TextBlock Text="CAM 1 • Toàn cảnh"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#666" FontSize="10" Margin="4,2"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <Image x:Name="CameraVao2" Stretch="Uniform"/>
                                <TextBlock Text="CAM 2 • Biển số"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#666" FontSize="10" Margin="4,2"/>
                                <!-- moved open gate button down under plate image -->
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Ảnh chụp 2 cam (xe vừa vào) -->
                    <Grid Grid.Row="4" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="Cam 1 – Xe vừa vào"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhChupVao1}" Stretch="Uniform" Margin="3"/>
                                <TextBlock Text="CHỤP 1" VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#F39C12" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="Cam 2 – Xe vừa vào"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhChupVao2}" Stretch="Uniform" Margin="3"/>
                                <TextBlock Text="CHỤP 2" VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#F39C12" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Plate image (nhỏ gọn) -->
                    <Border Grid.Row="5" Background="#0D1117" CornerRadius="4" Margin="0,0,0,2">
                        <Grid>
                            <TextBlock Text="Ảnh biển số nhận diện"
       VerticalAlignment="Center" HorizontalAlignment="Center"
       Foreground="#555" FontSize="10"/>
                            <Image Source="{Binding AnhBienSoVao}" Stretch="Uniform" Margin="4"/>
                            <Button Width="36" Height="24" Padding="2"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        Background="#2ECC71" Foreground="White" BorderThickness="0"
                        Click="OpenGateIn_Click"
                        ToolTip="Mở barrier vào">
                                🔓
                            </Button>
                            <TextBlock Text="BIỂN SỐ VÀO" VerticalAlignment="Top" HorizontalAlignment="Left"
       Foreground="#27AE60" FontSize="9" FontWeight="Bold" Margin="4,2"/>
                        </Grid>
                    </Border>

                    <!-- Info Card -->
                    <Border Grid.Row="6" Background="#F8F9FA" CornerRadius="6"
                Padding="10" Margin="0,0,0,4"
                BorderBrush="#E2E8F0" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Biển số:" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding LanVaoBienSo}"
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>

                            <TextBlock Grid.Row="1" Text="Mã thẻ:" Foreground="#666"
                           VerticalAlignment="Center" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LanVaoUID}"
                           FontSize="12" Foreground="#555" FontFamily="Consolas"
                           Margin="0,3,0,0"/>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                           Text="{Binding LanVaoTrangThai}"
                           FontSize="12" Foreground="#27AE60" FontWeight="SemiBold"
                           Margin="0,4,0,0"/>

                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <!--<StackPanel Grid.Row="2" Orientation="Horizontal">-->
                    <!-- Nhập biển số -->
                    <!--<TextBox Grid.Row="2" Height="32" FontSize="14"
            VerticalContentAlignment="Center"
            Text="{Binding BienSoNhap, UpdateSourceTrigger=PropertyChanged}"
            Margin="0,0,0,4"/>
        <Button Content="✅ Xe vào"
           Width="110" Height="32"
           Command="{Binding XeVaoCommand}"
           Background="#27AE60" Foreground="White"
           FontWeight="Bold" Margin="0,0,8,0"/>
        <Button Content="🔓 Mở Cổng Vào"
           Width="120" Height="32"
           Click="OpenGateIn_Click"
           Background="#2ECC71" Foreground="White"/>-->
                    <!--</StackPanel>-->
                    <!--<StackPanel Grid.Row="2" Orientation="Horizontal">-->
                    <!-- Nhập biển số -->
                    <!--<TextBox Grid.Row="2" Height="32" FontSize="14"
            VerticalContentAlignment="Center"
            Text="{Binding BienSoNhap, UpdateSourceTrigger=PropertyChanged}"
            Margin="0,0,0,4"/>
        <Button Content="✅ Xe vào"
           Width="110" Height="32"
           Command="{Binding XeVaoCommand}"
           Background="#27AE60" Foreground="White"
           FontWeight="Bold" Margin="0,0,8,0"/>
        <Button Content="🔓 Mở Cổng Vào"
           Width="120" Height="32"
           Click="OpenGateIn_Click"
           Background="#2ECC71" Foreground="White"/>-->
                    <!--</StackPanel>-->
                </Grid>
            </Border>

            <!-- ══════════ LUỒNG XE RA ══════════ -->
            <Border Grid.Column="4"
        Background="White" CornerRadius="8"
        BorderBrush="#E74C3C" BorderThickness="0,3,0,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Background="#E74C3C" CornerRadius="4" Padding="10,5" Margin="0,0,0,6">
                        <TextBlock Text="🔴 LUỒNG XE RA  ─  Gate 1 Reader 2"
                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- 2 Cameras side by side -->
                    <Grid Grid.Row="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <Image Stretch="Uniform"/>
                                <TextBlock Text="CAM 1 • Toàn cảnh"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#666" FontSize="10" Margin="4,2"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <Image Stretch="Uniform"/>
                                <TextBlock Text="CAM 2 • Biển số"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#666" FontSize="10" Margin="4,2"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Ảnh chụp 2 cam (xe vừa ra) -->
                    <Grid Grid.Row="4" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="Cam 1 – Xe vừa ra"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhChupRa1}" Stretch="Uniform" Margin="3"/>
                                <TextBlock Text="CHỤP 1" VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#F39C12" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="Cam 2 – Xe vừa ra"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhChupRa2}" Stretch="Uniform" Margin="3"/>
                                <TextBlock Text="CHỤP 2" VerticalAlignment="Top" HorizontalAlignment="Left"
                               Foreground="#F39C12" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 2 Plate images: VÀO vs RA (so sánh, nhỏ gọn) -->
                    <Grid Grid.Row="5" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="BS lúc VÀO"
           VerticalAlignment="Center" HorizontalAlignment="Center"
           Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhBienSoRaVao}" Stretch="Uniform" Margin="3"/>
                                <TextBlock Text="VÀO" VerticalAlignment="Top" HorizontalAlignment="Left"
           Foreground="#27AE60" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0D1117" CornerRadius="4">
                            <Grid>
                                <TextBlock Text="BS lúc RA"
           VerticalAlignment="Center" HorizontalAlignment="Center"
           Foreground="#555" FontSize="9"/>
                                <Image Source="{Binding AnhBienSoRaRa}" Stretch="Uniform" Margin="3"/>
                                <Button Width="36" Height="24" Padding="2"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,4,4,0"
                            Background="#E67E22" Foreground="White" BorderThickness="0"
                            Click="OpenGateOut_Click"
                            ToolTip="Mở barrier ra">
                                    🔓
                                </Button>
                                <TextBlock Text="RA" VerticalAlignment="Top" HorizontalAlignment="Left"
           Foreground="#E74C3C" FontSize="8" FontWeight="Bold" Margin="3,1"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Info Card -->
                    <Border Grid.Row="6" Background="#F8F9FA" CornerRadius="6"
                Padding="10" Margin="0,0,0,6"
                BorderBrush="#E2E8F0" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Biển số:" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding LanRaBienSo}"
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>

                            <TextBlock Grid.Row="1" Text="Thời gian:" Foreground="#666"
                           VerticalAlignment="Center" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LanRaThoiGianVao}"
                           FontSize="12" Foreground="#555" Margin="0,3,0,0"/>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                           Text="{Binding LanRaTien}"
                           FontSize="22" FontWeight="Bold" Foreground="#E74C3C"
                           Margin="0,4,0,2"/>

                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                           Text="{Binding LanRaTrangThai}"
                           FontSize="12" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                           Text="{Binding LanRaThoiGianTrongBai}"
                           FontSize="12" Foreground="#2C3E50"/>


                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>
        <!-- bottom realtime log removed; moved into left sidebar -->
        <!-- Hidden placeholders for cameras previously in RA panel (code-behind expects these names) -->
        <StackPanel Visibility="Collapsed">
            <Image x:Name="CameraRa1" />
            <Image x:Name="CameraRa2" />
        </StackPanel>
    </Grid>
</Window>