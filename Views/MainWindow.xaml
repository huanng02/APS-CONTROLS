<Window x:Class="QuanLyGiuXe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APS - Quản Lý Xe Ra/Vào"
        Height="800"
        Width="1280"
        WindowState="Maximized"
        xmlns:conv="clr-namespace:QuanLyGiuXe.Converters"
        xmlns:local="clr-namespace:QuanLyGiuXe.Views"
        xmlns:viewmodels="clr-namespace:QuanLyGiuXe.ViewModels"
        Background="{StaticResource BgLightBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ConnectionStatusToBrushConverter x:Key="StatusToBrush"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- STATUS BAR (APS BLUE) -->
        <Border Grid.Row="0" Background="{StaticResource APSBlueBrush}" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="APS" Foreground="White" FontSize="18" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Width="1" Background="#66FFFFFF" Margin="0,5,15,5"/>
                    <TextBlock Text="ACCESS CONTROL SYSTEM"
                               FontSize="14" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center" Opacity="0.9"/>
                </StackPanel>

                <!-- Connection Status Indicators -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Database monitor indicator -->
                    <Border Background="#26FFFFFF" CornerRadius="15" Padding="12,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding IsDbConnected, Converter={StaticResource StatusToBrush}}"/>
                            <TextBlock Text="{Binding DbStatusLabel}"
                                       Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- C3-200 monitor indicator -->
                    <Border Background="#26FFFFFF" CornerRadius="15" Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding IsC3Connected, Converter={StaticResource StatusToBrush}}"/>
                            <TextBlock Text="{Binding C3StatusLabel}"
                                       Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1" Margin="8,6,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource APSBlueBrush}" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Grid.Row="0">
                        <StackPanel Margin="10,20">
                            <TextBlock Text="MONITORING" Style="{StaticResource Heading2Style}" Foreground="#B0C4DE" FontSize="11" Margin="10,0,0,10"/>
                            <RadioButton Content="🚗 Quan sát &amp; Quét thẻ" Style="{StaticResource SidebarButtonStyle}" IsChecked="True" Click="MoParkingView_Click"/>
                            <RadioButton Content="📊 Thống kê Dashboard" Style="{StaticResource SidebarButtonStyle}" Click="MoDashboard_Click"/>
                            
                            <StackPanel x:Name="MenuVanHanh">
                                <TextBlock Text="LOGS &amp; MONITOR" Style="{StaticResource Heading2Style}" Foreground="#B0C4DE" FontSize="11" Margin="10,20,0,10"/>
                                <RadioButton Content="📋 Realtime Log" Style="{StaticResource SidebarButtonStyle}" Click="MoRealtimeLog_Click"/>
                                <RadioButton Content="📋 Button Logs" Style="{StaticResource SidebarButtonStyle}" Click="MoButtonLogs_Click"/>
                            </StackPanel>

                            <StackPanel x:Name="MenuBaoCao">
                                <TextBlock Text="HISTORY" Style="{StaticResource Heading2Style}" Foreground="#B0C4DE" FontSize="11" Margin="10,20,0,10"/>
                                <RadioButton Content="📜 Xe Ra / Vào" Style="{StaticResource SidebarButtonStyle}" Click="MoLichSu"/>
                                <RadioButton Content="📜 Gia hạn thẻ" Style="{StaticResource SidebarButtonStyle}" Click="MoLichSuGiaHan_Click"/>
                            </StackPanel>

                            <StackPanel x:Name="MenuAdmin">
                                <TextBlock Text="MANAGEMENT" Style="{StaticResource Heading2Style}" Foreground="#B0C4DE" FontSize="11" Margin="10,20,0,10"/>
                                <RadioButton Content="🚗 Loại xe" Style="{StaticResource SidebarButtonStyle}" Tag="LoaiXe" Click="OpenModule_Click"/>
                                <RadioButton Content="🎫 Loại vé" Style="{StaticResource SidebarButtonStyle}" Tag="LoaiVe" Click="OpenModule_Click"/>
                                <RadioButton Content="💳 Thẻ RFID" Style="{StaticResource SidebarButtonStyle}" Tag="RFID" Click="OpenModule_Click"/>
                                <RadioButton Content="💰 Bảng giá" Style="{StaticResource SidebarButtonStyle}" Tag="BangGia" Click="OpenModule_Click"/>
                                <RadioButton Content="👥 Người dùng" Style="{StaticResource SidebarButtonStyle}" Click="MoQuanLyNguoiDung_Click"/>
                            </StackPanel>

                            <StackPanel x:Name="MenuTools">
                                <TextBlock Text="SYSTEM" Style="{StaticResource Heading2Style}" Foreground="#B0C4DE" FontSize="11" Margin="10,20,0,10"/>
                                <RadioButton Content="📷 Camera" Style="{StaticResource SidebarButtonStyle}" Click="MoCameraSettings_Click"/>
                                <RadioButton Content="⚙ C3-200" Style="{StaticResource SidebarButtonStyle}" Click="MoC3200Settings_Click"/>
                                <RadioButton Content="🛠 SQL Tool" Style="{StaticResource SidebarButtonStyle}" Click="MoSQLTool_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Sidebar Footer -->
                    <Border Grid.Row="1" Background="#143A7D" Padding="15" CornerRadius="0,0,8,8">
                        <Grid Cursor="Hand" MouseLeftButtonUp="UserPanel_MouseLeftButtonUp" x:Name="UserPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#26FFFFFF" CornerRadius="18">
                                <TextBlock Text="👤" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUserTen}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="{Binding CurrentUserRole}" Foreground="#B0C4DE" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Stretch" />

            <!-- MAIN CONTENT AREA (DYNAMIC) -->
            <ContentControl x:Name="MainContentHost" Grid.Column="2" Grid.ColumnSpan="3" Content="{Binding CurrentView}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:TrangChuViewModel}">
                        <local:ParkingView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                        <local:DashboardView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- FOOTER / POPUPS -->
        <Popup x:Name="UserDetailPopup"
               IsOpen="{Binding IsUserPopupOpen, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=UserPanel}"
               Placement="Top" StaysOpen="False" AllowsTransparency="True">
            <Border Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="8" Width="240" Margin="0,0,10,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TÀI KHOẢN" FontWeight="Bold" FontSize="12" Margin="0,0,0,15" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="👤 Tên:" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentUserTen}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="🛡 Vai trò:" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentUserRole}" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}"/>
                    </Grid>
                    <Separator Margin="0,5,0,10"/>
                    <Button Content="⚙ Account Settings" Style="{StaticResource ModernOutlineButton}" Click="MoThongTinCaNhan_Click" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,8" BorderBrush="{StaticResource APSBlueBrush}" Foreground="{StaticResource APSBlueBrush}"/>
                    <Button Content="🔑 Change Password" Style="{StaticResource ModernOutlineButton}" Click="DoiMatKhau_Click" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,8" BorderBrush="{StaticResource APSBlueBrush}" Foreground="{StaticResource APSBlueBrush}"/>
                    <Button Content="🚪 Logout" Style="{StaticResource ModernOutlineButton}" Command="{Binding LogoutCommand}" Height="35" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- FOOTER BAR -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="15,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SoXeTrongBai}" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" 
                           Text="Hệ thống đang hoạt động bình thường" 
                           Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
            </Grid>
        </Border>

    </Grid>
</Window>
