                    <Border Grid.Row="1" Background="#143A7D" Padding="12" CornerRadius="0,0,8,8">
                        <Grid Cursor="Hand" MouseLeftButtonUp="UserPanel_MouseLeftButtonUp" x:Name="UserPanel" ToolTip="Thông tin cá nhân">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#26FFFFFF" CornerRadius="18">
                                <TextBlock Text="👤" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding CurrentUserTen}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="{Binding CurrentUserRole}" Foreground="#B0C4DE" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Stretch" />

            <!-- MAIN CONTENT AREA (DYNAMIC) -->
            <ContentControl x:Name="MainContentHost" Grid.Column="2" Grid.ColumnSpan="3" Content="{Binding CurrentView}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:TrangChuViewModel}">
                        <local:ParkingView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                        <local:DashboardView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:ParkingTopologyViewModel}">
                        <local:ParkingTopologyView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- FOOTER / POPUPS -->
        <Popup x:Name="UserDetailPopup"
               IsOpen="{Binding IsUserPopupOpen, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=UserPanel}"
               Placement="Top" StaysOpen="False" AllowsTransparency="True">
            <Border Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="8" Width="240" Margin="0,0,10,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TÀI KHOẢN" FontWeight="Bold" FontSize="12" Margin="0,0,0,15" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="👤 Tên:" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentUserTen}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="🛡 Vai trò:" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentUserRole}" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}"/>
                    </Grid>
                    <Separator Margin="0,5,0,10"/>
                    <Button Content="⚙ Account Settings" Style="{StaticResource ModernOutlineButton}" Click="MoThongTinCaNhan_Click" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,8" BorderBrush="{StaticResource APSBlueBrush}" Foreground="{StaticResource APSBlueBrush}"/>
                    <Button Content="🔑 Change Password" Style="{StaticResource ModernOutlineButton}" Click="DoiMatKhau_Click" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,8" BorderBrush="{StaticResource APSBlueBrush}" Foreground="{StaticResource APSBlueBrush}"/>
                    <Button Content="🚪 Logout" Style="{StaticResource ModernOutlineButton}" Command="{Binding LogoutCommand}" Height="35" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- FOOTER BAR -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="15,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SoXeTrongBai}" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" 
                           Text="Hệ thống đang hoạt động bình thường" 
                           Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
            </Grid>
        </Border>

    </Grid>
</Window>
