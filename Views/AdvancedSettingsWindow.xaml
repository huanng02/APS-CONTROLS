<Window x:Class="QuanLyGiuXe.Views.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Exit Control" Height="600" Width="950" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgLightBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource APSBlueBrush}" Padding="15" CornerRadius="8,8,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔒" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="ADVANCED EXIT FLOW CONFIGURATION" Style="{StaticResource Heading2Style}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
            <StackPanel>
                <TextBlock Text="EXIT CAMERA FEEDS" Style="{StaticResource SubTitleStyle}" Margin="5,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="#000" CornerRadius="6" Height="200" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                        <Image Source="{Binding AnhChupRa1}" Stretch="Uniform" Margin="2"/>
                    </Border>
                    <Border Grid.Column="2" Background="#000" CornerRadius="6" Height="200" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                        <Image Source="{Binding AnhChupRa2}" Stretch="Uniform" Margin="2"/>
                    </Border>
                </Grid>

                <TextBlock Text="PLATE RECOGNITION" Style="{StaticResource SubTitleStyle}" Margin="5,20,0,10" />
                <Border Background="#000" CornerRadius="6" Height="140" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                    <Grid>
                        <Image Source="{Binding AnhBienSoRaRa}" Stretch="Uniform" Margin="2"/>
                        <Button Style="{StaticResource DangerButton}" Width="45" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                                Content="🔓" ToolTip="Emergency Open" Click="OpenGateOut_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource EnterpriseCardBorder}" Padding="20">
                <StackPanel>
                    <TextBlock Text="EXIT VEHICLE INFO" Style="{StaticResource Heading2Style}" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15" />

                    <TextBlock Text="PLATE NUMBER" Style="{StaticResource BaseTextBlockStyle}" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding Lane2BienSo}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource APSBlueBrush}" Margin="0,0,0,15"/>

                    <TextBlock Text="STATUS" Style="{StaticResource BaseTextBlockStyle}" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding Lane2TrangThai}" FontSize="14" Foreground="{StaticResource APSRedBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="FEE" Style="{StaticResource BaseTextBlockStyle}" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding Lane2Tien}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,15"/>

                    <TextBlock Text="ENTRY TIME" Style="{StaticResource BaseTextBlockStyle}" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding Lane2ThoiGianVao}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <Separator Background="{StaticResource BorderLightBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="MANUAL PLATE ENTRY" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Style="{StaticResource ModernTextBox}" Width="200" Height="36" 
                                 Text="{Binding BienSoNhap, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Style="{StaticResource ModernButton}" Width="120" Height="36" Margin="10,0,0,0" 
                                Command="{Binding XeRaCommand}" Content="✅ CONFIRM EXIT"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Style="{StaticResource ModernOutlineButton}" Width="120" Content="CLOSE" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
