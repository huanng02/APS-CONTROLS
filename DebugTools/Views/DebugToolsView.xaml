<Window x:Class="QuanLyGiuXe.DebugTools.Views.DebugToolsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyGiuXe.DebugTools.Views"
        mc:Ignorable="d"
        Title="APS-CONTROLS QA / AUTO TEST PANEL" Height="750" Width="1050"
        Background="#0F111A" Foreground="White"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Palette -->
        <SolidColorBrush x:Key="CardBg" Color="#1A1D29"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#25293D"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4D9BFF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00E676"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FF5252"/>
        <SolidColorBrush x:Key="TextMain" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDim" Color="#A0A8C1"/>
        
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
        </Style>

        <Style x:Key="TestBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D324A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3D4466"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D4466"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,25" BorderBrush="#25293D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Border Background="{StaticResource AccentBlue}" Width="50" Height="50" CornerRadius="10" Margin="0,0,15,0">
                    <TextBlock Text="QA" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="APS-CONTROLS STABILITY DASHBOARD" FontSize="22" FontWeight="Black" Foreground="White"/>
                    <TextBlock Text="INTERNAL AUTOMATION &amp; STRESS TESTING TOOLKIT" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Control Panel -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <!-- Exceptions -->
                    <Border Background="{StaticResource CardBg}" Padding="20" CornerRadius="12" Margin="0,0,0,15" BorderBrush="#25293D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PHASE 1: Exception Handling" Style="{StaticResource SectionHeader}"/>
                            <UniformGrid Columns="2">
                                <Button Content="UI Crash" Command="{Binding UIExceptionCommand}" Style="{StaticResource TestBtn}" Background="#2D1F24" BorderBrush="#4A2B34"/>
                                <Button Content="Async Crash" Command="{Binding AsyncExceptionCommand}" Style="{StaticResource TestBtn}" Background="#2D1F24" BorderBrush="#4A2B34"/>
                                <Button Content="Background" Command="{Binding BgExceptionCommand}" Style="{StaticResource TestBtn}" Background="#2D1F24" BorderBrush="#4A2B34"/>
                                <Button Content="Nested Err" Command="{Binding NestedExceptionCommand}" Style="{StaticResource TestBtn}" Background="#2D1F24" BorderBrush="#4A2B34"/>
                                <Button Content="Spam 100x" Command="{Binding SpamExceptionCommand}" Style="{StaticResource TestBtn}" Grid.ColumnSpan="2" Margin="0,5,0,0" Foreground="{StaticResource AccentRed}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Connection -->
                    <Border Background="{StaticResource CardBg}" Padding="20" CornerRadius="12" Margin="0,0,0,15" BorderBrush="#25293D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PHASE 2: Auto Reconnect" Style="{StaticResource SectionHeader}" Foreground="#FFA000"/>
                            <UniformGrid Columns="2">
                                <Button Content="Kill SQL Conn" Command="{Binding DisconnectSqlCommand}" Style="{StaticResource TestBtn}" Background="#2D271F" BorderBrush="#4A3F2B"/>
                                <Button Content="Restore SQL" Command="{Binding ReconnectSqlCommand}" Style="{StaticResource TestBtn}" Background="#1F2D24" BorderBrush="#2B4A34"/>
                                <Button Content="Ping Failure" Command="{Binding NetworkFailureCommand}" Style="{StaticResource TestBtn}" Grid.ColumnSpan="2" Margin="0,5,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Backup -->
                    <Border Background="{StaticResource CardBg}" Padding="20" CornerRadius="12" Margin="0,0,0,15" BorderBrush="#25293D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PHASE 3: Integrity Check" Style="{StaticResource SectionHeader}" Foreground="{StaticResource AccentGreen}"/>
                            <StackPanel>
                                <Button Content="Verify Real Backup" Command="{Binding CreateBackupCommand}" Style="{StaticResource TestBtn}" Background="#1F2D24" BorderBrush="#2B4A34" HorizontalAlignment="Stretch"/>
                                <Button Content="Simulate Corruption" Command="{Binding CreateFakeBackupCommand}" Style="{StaticResource TestBtn}" Background="#2D1F24" BorderBrush="#4A2B34" HorizontalAlignment="Stretch"/>
                                <Button Content="Stress Backup (5x)" Command="{Binding StressBackupCommand}" Style="{StaticResource TestBtn}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="PURGE ALL TEST LOGS" Command="{Binding ClearResultsCommand}" Style="{StaticResource TestBtn}" Background="#444444" BorderBrush="#666666" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Results DataGrid -->
            <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="12" Padding="0" BorderBrush="#25293D" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Background="{StaticResource HeaderBg}" Padding="20,15">
                        <Grid>
                            <TextBlock Text="REAL-TIME EXECUTION LOG" Style="{StaticResource SectionHeader}" Margin="0"/>
                            <TextBlock Text="{Binding TestResults.Count, StringFormat='Total: {0}'}" HorizontalAlignment="Right" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TestResults}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" Foreground="White"
                              IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#25293D" RowHeight="45" SelectionUnit="FullRow">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1E2235"/>
                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#25293D"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#25293D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIME" Binding="{Binding DisplayTimestamp}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="TEST CASE" Binding="{Binding TestName}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTemplateColumn Header="STATUS" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Success, Converter={StaticResource BooleanToBrushConverter}}" 
                                                CornerRadius="12" Padding="8,2" HorizontalAlignment="Left" Width="70">
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" 
                                                       FontWeight="Black" FontSize="10" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTextColumn Header="RESULT DETAILS" Binding="{Binding ErrorMessage}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Success}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Success}" Value="True">
                                                <Setter Property="Foreground" Value="#BBBBBB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Margin="0,20,0,0" Padding="15,10" Background="#1A1D29" CornerRadius="8" BorderBrush="#25293D" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="BUILD: v2026.05.13-DEBUG" HorizontalAlignment="Right" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
